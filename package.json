{
  "name": "maple",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --ui=tui",
    "dev:alerting": "bun --filter=@maple/alerting dev",
    "build": "vp run -r build",
    "typecheck": "vp run -r typecheck",
    "test": "vp run -r test",
    "tinybird:manifest": "bun run ./scripts/generate-tinybird-project-manifest.ts",
    "tinybird:manifest:check": "bun run ./scripts/generate-tinybird-project-manifest.ts --check",
    "deploy:prd": "bun scripts/deploy-stack.ts deploy prd",
    "destroy:prd": "bun scripts/deploy-stack.ts destroy prd",
    "deploy:stg": "bun scripts/deploy-stack.ts deploy stg",
    "destroy:stg": "bun scripts/deploy-stack.ts destroy stg",
    "deploy:pr": "bun scripts/deploy-stack.ts deploy pr",
    "destroy:pr": "bun scripts/deploy-stack.ts destroy pr",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@tinybirdco/sdk": "catalog:tinybird",
    "turbo": "^2.8.21",
    "typescript": "catalog:tooling",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.8",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "0.1.15-alpha.5"
  },
  "catalogs": {
    "effect": {
      "effect": "4.0.0-beta.33",
      "@effect/atom-react": "4.0.0-beta.33",
      "@effect/opentelemetry": "4.0.0-beta.33",
      "@effect/platform-bun": "4.0.0-beta.33",
      "@effect/language-service": "^0.75.1"
    },
    "react": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    },
    "tailwind": {
      "tailwindcss": "^4.2.2",
      "@tailwindcss/vite": "^4.2.2",
      "tailwind-merge": "^3.5.0",
      "tw-animate-css": "^1.4.0"
    },
    "ui": {
      "@base-ui/react": "^1.3.0",
      "@xyflow/react": "^12.10.2",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "recharts": "2.15.4"
    },
    "tooling": {
      "typescript": "^6.0.2",
      "@types/node": "^22.10.2"
    },
    "tinybird": {
      "@tinybirdco/sdk": "0.0.64"
    }
  }
}
