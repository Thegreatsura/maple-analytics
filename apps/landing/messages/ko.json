  "faq_badge": "FAQ",
  "faq_heading": "\uc790\uc8fc \ubb3b\ub294 \uc9c8\ubb38",
  "faq_ingestion_q": "\ub370\uc774\ud130 \uc218\uc9d1\uc740 \uc5b4\ub5bb\uac8c \uc791\ub3d9\ud558\ub098\uc694?",
  "faq_ingestion_a": "Maple\uc740 \uc804\uc1a1\ud558\ub294 \ub370\uc774\ud130 \ubcfc\ub968\uc73c\ub85c \uc218\uc9d1\uc744 \uce21\uc815\ud569\ub2c8\ub2e4. \ub85c\uadf8, \ud2b8\ub808\uc774\uc2a4, \uba54\ud2b8\ub9ad\uc740 \uac01\uac01 \uae30\uac00\ubc14\uc774\ud2b8 \ub2e8\uc704\ub85c \uce21\uc815\ub429\ub2c8\ub2e4. \uac01 \ud50c\ub79c\uc5d0\ub294 \uc2e0\ud638 \uc720\ud615\ubcc4 \uc6d4\uac04 \ub370\uc774\ud130 \ud560\ub2f9\ub7c9\uc774 \ud3ec\ud568\ub429\ub2c8\ub2e4.",
  "faq_limits_q": "\ud50c\ub79c \ud55c\ub3c4\ub97c \ucd08\uacfc\ud558\uba74 \uc5b4\ub5bb\uac8c \ub418\ub098\uc694?",
  "faq_limits_a": "\ud55c\ub3c4\uc5d0 \uadfc\uc811\ud558\uba74 \uc54c\ub824\ub4dc\ub9bd\ub2c8\ub2e4. Starter \ud50c\ub79c\uc5d0\uc11c\ub294 \ud55c\ub3c4\uc5d0 \ub3c4\ub2ec\ud558\uba74 \uc218\uc9d1\uc774 \uc77c\uc2dc \uc911\uc9c0\ub429\ub2c8\ub2e4. Startup \ud50c\ub79c\uc5d0\uc11c\ub294 \ucd94\uac00 \uc0ac\uc6a9\ub7c9\uc774 \ud22c\uba85\ud55c GB\ub2f9 \uc694\uae08\uc73c\ub85c \uacfc\uae08\ub429\ub2c8\ub2e4.",
  "faq_retention_q": "\ub370\uc774\ud130 \ubcf4\uc874 \uae30\uac04\uc740 \uc5bc\ub9c8\ub098 \ub418\ub098\uc694?",
  "faq_retention_a": "\ubcf4\uc874 \uae30\uac04\uc740 \ud50c\ub79c\uc5d0 \ub530\ub77c \ub2e4\ub985\ub2c8\ub2e4. Starter \ud50c\ub79c\uc740 14\uc77c, Startup\uc740 30\uc77c, Enterprise \ud50c\ub79c\uc740 \ub9de\ucda4\ud615 \ubcf4\uc874 \uae30\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ud50c\ub79c\uc5d0\uc11c \ubcf4\uc874\ub41c \ub370\uc774\ud130\uc5d0 \ub300\ud55c \uc644\uc804\ud55c \ucffc\ub9ac \uc561\uc138\uc2a4\uac00 \ud3ec\ud568\ub429\ub2c8\ub2e4.",
  "faq_otel_q": "Maple\uc740 OpenTelemetry\uc640 \ud638\ud658\ub418\ub098\uc694?",
  "faq_otel_a": "\ub124. Maple\uc740 OpenTelemetry \uae30\ubc18\uc73c\ub85c \ub124\uc774\ud2f0\ube0c\ud558\uac8c \uad6c\ucd95\ub418\uc5c8\uc2b5\ub2c8\ub2e4. OTel SDK \ub610\ub294 OTel Collector\ub85c \uacc4\uce21\ub41c \uc560\ud50c\ub9ac\ucf00\uc774\uc158\uc740 \ucf54\ub4dc \ubcc0\uacbd \uc5c6\uc774 Maple\ub85c \uc9c1\uc811 \ub370\uc774\ud130\ub97c \uc804\uc1a1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
  "faq_selfhost_q": "Maple\uc744 \uc140\ud504 \ud638\uc2a4\ud305\ud560 \uc218 \uc788\ub098\uc694?",
  "faq_selfhost_a": "\ubb3c\ub860\uc785\ub2c8\ub2e4. Maple\uc740 \uc644\uc804\ud55c \uc624\ud508\uc18c\uc2a4\ub85c \uc790\uccb4 \uc778\ud504\ub77c\uc5d0\uc11c \uc140\ud504 \ud638\uc2a4\ud305 \uac00\ub2a5\ud569\ub2c8\ub2e4. \uad00\ub9ac\ud615 \uacbd\ud5d8\uc744 \uc6d0\ud558\ub294 \ud300\uc744 \uc704\ud55c \ud074\ub77c\uc6b0\ub4dc \ud50c\ub79c\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4.",
  "faq_trial_q": "\uc720\ub8cc \ud50c\ub79c\uc5d0 \ubb34\ub8cc \uccb4\ud5d8\uc774 \uc788\ub098\uc694?",
  "faq_trial_a": "\ub124, \ubaa8\ub4e0 \ud50c\ub79c\uc5d0\ub294 \ubb34\ub8cc \uccb4\ud5d8\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc5b4 \ucee4\ubc0b \uc804\uc5d0 \ubaa8\ub4e0 \uae30\ub2a5\uc744 \ud0d0\uc0c9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",

  "page_home_title": "\ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8 & \uba54\ud2b8\ub9ad \uc624\ud508\uc18c\uc2a4 \uc635\uc800\ubc84\ube4c\ub9ac\ud2f0 \u2014 Maple",
  "page_home_desc": "OpenTelemetry \uae30\ubc18\uc758 \uc624\ud508\uc18c\uc2a4 \uc635\uc800\ubc84\ube4c\ub9ac\ud2f0 \ud50c\ub7ab\ud3fc. AI \uae30\ubc18 \uc9c4\ub2e8\uc73c\ub85c \ubd84\uc0b0 \ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8, \uba54\ud2b8\ub9ad\uc744 \uc218\uc9d1, \uc2dc\uac01\ud654, \ubd84\uc11d.",

  "page_pricing_title": "\uc2ec\ud50c\ud558\uace0 \ud22c\uba85\ud55c \uc694\uae08 \u2014 Maple",
  "page_pricing_desc": "\ub85c\uadf8, \ud2b8\ub808\uc774\uc2a4, \uba54\ud2b8\ub9ad\uc758 \ucda9\ubd84\ud55c \ub370\uc774\ud130 \ud55c\ub3c4\ub85c \ubb34\ub8cc \uc2dc\uc791. \ud22c\uba85\ud55c \uc885\ub7c9 \uacfc\uae08\uc73c\ub85c \ud655\uc7a5. \uc0ac\uc6a9\uc790\ub2f9 \uc694\uae08\uc774\ub098 \uc228\uaca8\uc9c4 \ube44\uc6a9 \uc5c6\uc74c.",
  "page_pricing_label": "\uc694\uae08",
  "page_pricing_heading": "\uc2ec\ud50c\ud558\uace0 \ud22c\uba85\ud55c \uc694\uae08",
  "page_pricing_subtitle": "\ucda9\ubd84\ud55c \ud55c\ub3c4\ub85c \ubb34\ub8cc \uc2dc\uc791. \uc885\ub7c9 \uacfc\uae08\uc73c\ub85c \uc131\uc7a5\uc5d0 \ub9de\ucdb0 \ud655\uc7a5 \u2014 \uc0ac\uc6a9\uc790\ub2f9 \uc694\uae08 \uc5c6\uc74c, \uc228\uaca8\uc9c4 \ube44\uc6a9 \uc5c6\uc74c, \ubca4\ub354 \ub77d\uc778 \uc5c6\uc74c.",

  "page_otel_title": "OpenTelemetry \uc635\uc800\ubc84\ube4c\ub9ac\ud2f0 \ud50c\ub7ab\ud3fc \u2014 Maple",
  "page_otel_desc": "Maple\uc740 OpenTelemetry \uae30\ubc18\uc73c\ub85c \ub124\uc774\ud2f0\ube0c \uad6c\ucd95. OTLP\ub85c \ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8, \uba54\ud2b8\ub9ad \uc218\uc9d1 \u2014 \ub3c5\uc810 \uc5d0\uc774\uc804\ud2b8 \ubd88\ud544\uc694, \ubca4\ub354 \ub77d\uc778 \uc5c6\uc74c.",
  "page_otel_label": "OpenTelemetry",
  "page_otel_heading": "OpenTelemetry\ub97c \uae30\ubc18\ubd80\ud130 \uad6c\ucd95",
  "page_otel_subtitle": "Maple\uc740 \uc644\uc804\ud55c OTel \ub124\uc774\ud2f0\ube0c \uc635\uc800\ubc84\ube4c\ub9ac\ud2f0 \ud50c\ub7ab\ud3fc. \ubaa8\ub4e0 \uc2e0\ud638 \u2014 \ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8, \uba54\ud2b8\ub9ad \u2014 \uac00 \uc624\ud508 \ud45c\uc900\uc744 \ud1b5\ud574 \ud750\ub985\ub2c8\ub2e4.",
  "page_otel_standard": "\ud45c\uc900",
  "page_otel_what_is": "OpenTelemetry\ub780?",
  "page_otel_what_is_p1": "OpenTelemetry\ub294 \ubd84\uc0b0 \uc2dc\uc2a4\ud15c\uc5d0\uc11c \uc635\uc800\ubc84\ube4c\ub9ac\ud2f0 \ub370\uc774\ud130\ub97c \uc218\uc9d1\ud558\uae30 \uc704\ud55c CNCF \uc624\ud508\uc18c\uc2a4 \ud45c\uc900\uc785\ub2c8\ub2e4. \ubca4\ub354 \uc911\ub9bd\uc801\uc778 API, SDK, \ub3c4\uad6c\uc758 \ud1b5\ud569 \uc138\ud2b8\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.",
  "page_otel_what_is_p2": "\ubaa8\ub4e0 \uc8fc\uc694 \uc5b8\uc5b4\uc640 \ud504\ub808\uc784\uc6cc\ud06c\ub97c \uc9c0\uc6d0\ud558\uba70, OTel\uc740 \ud154\ub808\uba54\ud2b8\ub9ac \uacc4\uce21\uc758 \uc5c5\uacc4 \uae30\ubcf8\uc774 \ub418\uc5c8\uc2b5\ub2c8\ub2e4.",
  "page_otel_approach": "\uc811\uadfc \ubc29\uc2dd",
  "page_otel_why_heading": "OpenTelemetry\ub85c \uad6c\ucd95\ud558\ub294 \uc774\uc720",
  "page_otel_no_vendor": "\ubca4\ub354 \ub77d\uc778 \uc5c6\uc74c",
  "page_otel_no_vendor_desc": "\uc5b4\ub5a4 \ubc31\uc5d4\ub4dc\ub97c \uc120\ud0dd\ud558\ub4e0 \uacc4\uce21\uc740 \ub3d9\uc77c. \uc560\ud50c\ub9ac\ucf00\uc774\uc158 \ucf54\ub4dc \ubcc0\uacbd \uc5c6\uc774 \ud504\ub85c\ubc14\uc774\ub354 \uc804\ud658 \uac00\ub2a5.",
  "page_otel_one_standard": "\ud558\ub098\uc758 \ud45c\uc900, \ubaa8\ub4e0 \uc2e0\ud638",
  "page_otel_one_standard_desc": "\ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8, \uba54\ud2b8\ub9ad\uc774 \uc0c1\uad00 \ucee8\ud14d\uc2a4\ud2b8\ub97c \uac00\uc9c4 \ud1b5\ud569 \ub370\uc774\ud130 \ubaa8\ub378\uc744 \uacf5\uc720. \ubcc4\ub3c4 \ub3c4\uad6c\ub97c \uc5f0\uacb0\ud560 \ud544\uc694 \uc5c6\uc74c.",
  "page_otel_community": "\ucee4\ubba4\ub2c8\ud2f0 \uc8fc\ub3c4",
  "page_otel_community_desc": "CNCF\uc640 \uc218\ubc31 \uba85\uc758 \uae30\uc5ec\uc790\uac00 \uc9c0\uc6d0. \uc0ac\uc591\uc740 \ub2e8\uc77c \ubca4\ub354\uac00 \uc544\ub2cc \uc2e4\uc81c \uc694\uad6c\uc5d0 \ub530\ub77c \ubc1c\uc804.",
  "page_otel_language": "\uad11\ubc94\uc704\ud55c \uc5b8\uc5b4 \uc9c0\uc6d0",
  "page_otel_language_desc": "Go, Java, Python, JavaScript, .NET, Rust \ub4f1\uc758 \uacf5\uc2dd SDK. \ub300\ubd80\ubd84\uc758 \ud504\ub808\uc784\uc6cc\ud06c\uc5d0\uc11c \uc790\ub3d9 \uacc4\uce21 \uc0ac\uc6a9 \uac00\ub2a5.",
  "page_otel_future": "\ubbf8\ub798 \ub300\ube44 \uc124\uacc4",
  "page_otel_future_desc": "\uc5c5\uacc4\uac00 OTel\ub85c \uc218\ub834\ud558\uba74\uc11c \uacc4\uce21 \ud22c\uc790\uac00 \ubbf8\ub798\uc5d0\ub3c4 \uc720\ud6a8. \ub354 \uc774\uc0c1 \ub9bd \uc564 \ub9ac\ud50c\ub808\uc774\uc2a4 \ub9c8\uc774\uadf8\ub808\uc774\uc158\uc774 \ud544\uc694 \uc5c6\uc2b5\ub2c8\ub2e4.",
  "page_otel_ecosystem_title": "\ud48d\ubd80\ud55c \uc0dd\ud0dc\uacc4",
  "page_otel_ecosystem_desc": "\ucee4\ub809\ud130, \uc775\uc2a4\ud3ec\ud130, \ud504\ub85c\uc138\uc11c, \ucee4\ub125\ud130 \u2014 \uc778\ud504\ub77c\uc5d0 \ub9de\uac8c \ucee4\uc2a4\ud130\ub9c8\uc774\uc988 \uac00\ub2a5\ud55c \ud480 \ud30c\uc774\ud504\ub77c\uc778.",
  "page_otel_spec": "\uc0ac\uc591 \uc900\uc218",
  "page_otel_spec_heading": "Maple\uc758 \uc0ac\uc591 \uc900\uc218",
  "page_otel_spec_otlp": "\ub124\uc774\ud2f0\ube0c OTLP \uc218\uc9d1",
  "page_otel_spec_otlp_desc": "OTLP/gRPC \ub610\ub294 OTLP/HTTP\ub85c \ud154\ub808\uba54\ud2b8\ub9ac\ub97c \uc9c1\uc811 \uc804\uc1a1. \ubcc0\ud658 \ub808\uc774\uc5b4\ub098 \ub3c5\uc810 \ud3ec\ub9f7 \ubd88\ud544\uc694.",
  "page_otel_spec_semantic": "\uc2dc\ub9e8\ud2f1 \ucee8\ubca4\uc158",
  "page_otel_spec_semantic_desc": "Maple\uc740 OTel \uc2dc\ub9e8\ud2f1 \ucee8\ubca4\uc158\uc744 \uc774\ud574\ud558\uace0 \uc778\ub371\uc2f1 \u2014 HTTP, \ub370\uc774\ud130\ubca0\uc774\uc2a4, RPC, \uba54\uc2dc\uc9d5 \u2014 \ubc14\ub85c \uc0ac\uc6a9 \uac00\ub2a5.",
  "page_otel_spec_signals": "3\uac00\uc9c0 \uc2e0\ud638 \ubaa8\ub450",
  "page_otel_spec_signals_desc": "\ud2b8\ub808\uc774\uc2a4, \ub85c\uadf8, \uba54\ud2b8\ub9ad\uc758 \ud37c\uc2a4\ud2b8 \ud074\ub798\uc2a4 \uc9c0\uc6d0. \uac01 \uc2e0\ud638\ub294 \ub124\uc774\ud2f0\ube0c\ub85c \uc800\uc7a5, \ucffc\ub9ac, \uc0c1\uad00\ub429\ub2c8\ub2e4.",
  "page_otel_spec_collector": "Collector \ud638\ud658",
  "page_otel_spec_collector_desc": "OpenTelemetry Collector\ub97c \uc0ac\uc6a9\ud558\uc5ec Maple\ub85c \uc804\uc1a1 \uc804\uc5d0 \ud154\ub808\uba54\ud2b8\ub9ac\ub97c \ub77c\uc6b0\ud305, \ud544\ud130\ub9c1, \ubc30\uce58 \ucc98\ub9ac.",
  "page_otel_spec_sdk": "\ubaa8\ub4e0 OTel SDK",
  "page_otel_spec_sdk_desc": "\ubaa8\ub4e0 \uacf5\uc2dd OTel SDK\uc640 \ud638\ud658. OTLP\ub97c \uc9c0\uc6d0\ud558\uba74 Maple\uc774 \uc218\uc9d1 \uac00\ub2a5 \u2014 \ubca4\ub354 \ud2b9\uc815 \ub77c\uc774\ube0c\ub7ec\ub9ac \ubd88\ud544\uc694.",
  "page_otel_spec_context": "\ucee8\ud14d\uc2a4\ud2b8 \uc804\ud30c",
  "page_otel_spec_context_desc": "W3C Trace Context \ubc0f Baggage \uc804\ud30c \uc9c0\uc6d0. \uc11c\ube44\uc2a4 \uacbd\uacc4\ub97c \ub118\uc5b4 \uc2a4\ud32c, \ub85c\uadf8, \uba54\ud2b8\ub9ad\uc744 \uc0c1\uad00.",
  "page_otel_ecosystem": "\uc0dd\ud0dc\uacc4",
  "page_otel_ecosystem_heading": "\uae30\uc874 OTel \uc124\uc815\uacfc \uc5f0\ub3d9",
  "page_otel_ecosystem_p1": "OpenTelemetry Collector, \uc790\ub3d9 \uacc4\uce21 \uc5d0\uc774\uc804\ud2b8 \ub610\ub294 OTel SDK\ub97c \uc774\ubbf8 \uc0ac\uc6a9 \uc911? OTLP \uc775\uc2a4\ud3ec\ud130\ub97c Maple\ub85c \ud5a5\ud558\uba74 \uc989\uc2dc \ub370\uc774\ud130\uac00 \ud45c\uc2dc\ub429\ub2c8\ub2e4.",
  "page_otel_ecosystem_p2": "Maple\uc740 OTel \uc0dd\ud0dc\uacc4\uc758 \ubc31\uc5d4\ub4dc\ub85c \uae30\ub2a5\ud569\ub2c8\ub2e4. \uae30\uc874 \uacc4\uce21\uc744 \uc911\ub2e8\ud558\uc9c0 \uc54a\uace0 Maple\uc744 \ub3c4\uc785\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",

  "page_roadmap_title": "\ub85c\ub4dc\ub9f5 \u2014 Maple",
  "page_roadmap_desc": "\uad6c\ucd95 \uc911\uc778 \uac83, \uc9c4\ud589 \uc911\uc778 \uac83, \ucd9c\uc2dc\ub41c \uac83\uc744 \ud655\uc778\ud558\uc138\uc694. Maple\uc758 \uac1c\ubc1c \ub85c\ub4dc\ub9f5\uc740 \ud22c\uba85\ud558\uace0 \uc815\uae30\uc801\uc73c\ub85c \uc5c5\ub370\uc774\ud2b8\ub429\ub2c8\ub2e4.",
  "page_roadmap_label": "\ub85c\ub4dc\ub9f5",
  "page_roadmap_heading": "\uad6c\ucd95 \uc911\uc778 \uac83",
  "page_roadmap_subtitle": "Maple \uac1c\ubc1c\uc758 \ud22c\uba85\ud55c \ubdf0. \ucd9c\uc2dc\ub41c \uac83, \uc9c4\ud589 \uc911\uc778 \uac83, \ud5a5\ud6c4 \ubc29\ud5a5\uc744 \ud655\uc778\ud558\uc138\uc694.",

  "page_dt_title": "\ubd84\uc0b0 \ud2b8\ub808\uc774\uc2f1 | Maple",
  "page_dt_desc": "\ud50c\ub808\uc784\uadf8\ub798\ud504\uc640 \uc6cc\ud130\ud3f4 \ubdf0\ub85c \uc11c\ube44\uc2a4 \uac04 \uc694\uccad \ud750\ub984\uc744 \uc2dc\uac01\ud654. \ubaa8\ub4e0 \uc2a4\ud32c\uc758 \uc18d\uc131, \uc774\ubca4\ud2b8, \ud0c0\uc774\ubc0d \ud655\uc778.",
