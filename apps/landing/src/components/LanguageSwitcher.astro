---
import { getRelativeLocaleUrl } from "astro:i18n";
import * as m from "../paraglide/messages";

const currentLocale = Astro.currentLocale ?? "en";
const locales = [
    { code: "en", label: m.language_en() },
    { code: "ja", label: m.language_ja() },
    { code: "ko", label: m.language_ko() },
] as const;

const pathWithoutLocale = Astro.url.pathname
    .replace(/^\/(ja|ko)(\/|$)/, "/")
    .replace(/\/+/g, "/");
---

<div class="relative" data-language-switcher>
    <button
        type="button"
        class="flex items-center gap-1.5 text-xs text-muted hover:text-fg transition-colors px-2 py-1 rounded-md hover:bg-white/5"
        aria-label="Change language"
        data-switcher-trigger
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
            <path d="M2 12h20"></path>
        </svg>
        <span>{locales.find(l => l.code === currentLocale)?.label}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"></path>
        </svg>
    </button>
    <div class="absolute right-0 bottom-full mb-1 bg-bg border border-border rounded-lg shadow-lg py-1 min-w-[120px] hidden" data-switcher-menu>
        {locales.map((locale) => (
            <a
                href={getRelativeLocaleUrl(locale.code, pathWithoutLocale)}
                class:list={[
                    "block px-3 py-1.5 text-xs transition-colors",
                    locale.code === currentLocale
                        ? "text-primary font-medium"
                        : "text-muted hover:text-fg hover:bg-white/5",
                ]}
            >
                {locale.label}
            </a>
        ))}
    </div>
</div>

<script>
    document.querySelectorAll("[data-language-switcher]").forEach((switcher) => {
        const trigger = switcher.querySelector("[data-switcher-trigger]");
        const menu = switcher.querySelector("[data-switcher-menu]");
        if (!trigger || !menu) return;

        trigger.addEventListener("click", () => {
            menu.classList.toggle("hidden");
        });

        document.addEventListener("click", (e) => {
            if (!switcher.contains(e.target as Node)) {
                menu.classList.add("hidden");
            }
        });
    });
</script>
