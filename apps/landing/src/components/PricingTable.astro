---
import { Autumn } from "autumn-js"
import * as m from "../paraglide/messages";

const HIDDEN_FEATURE_IDS = new Set<string>(["ai_input_tokens", "ai_output_tokens"])

// Capitalized, localized labels for the metered data rows, keyed by Autumn
// featureId (Autumn returns lowercase names like "logs"). Drives the row text;
// the icon is matched on featureId in the template.
const DATA_FEATURE_LABELS: Record<string, string> = {
    logs: m.pricing_logs(),
    traces: m.pricing_traces(),
    metrics: m.pricing_metrics(),
}

// Canonical row order so the plan card matches the Enterprise card (Autumn can
// return items in any order).
const DATA_FEATURE_ORDER = ["logs", "traces", "metrics"]
const dataFeatureRank = (id: string | undefined) => {
    const i = id ? DATA_FEATURE_ORDER.indexOf(id) : -1
    return i === -1 ? DATA_FEATURE_ORDER.length : i
}

const PLAN_FEATURES: Record<string, { label: string; value: string }[]> = {
    starter: [
        { label: m.pricing_14day_retention(), value: "" },
        { label: m.pricing_unlimited_dashboards(), value: "" },
        { label: m.pricing_advanced_alerting(), value: "" },
        { label: m.pricing_mcp_server(), value: "" },
        { label: m.pricing_ai_chat(), value: "" },
        { label: m.pricing_ai_triage(), value: "" },
        { label: m.pricing_full_api(), value: "" },
        { label: m.pricing_email_support(), value: "" },
    ],
    startup: [
        { label: m.pricing_30day_retention(), value: "" },
        { label: m.pricing_unlimited_dashboards(), value: "" },
        { label: m.pricing_advanced_alerting(), value: "" },
        { label: m.pricing_mcp_server(), value: "" },
        { label: m.pricing_ai_chat(), value: "" },
        { label: m.pricing_ai_triage(), value: "" },
        { label: m.pricing_full_api(), value: "" },
        { label: m.pricing_private_channel(), value: "" },
    ],
}

interface PlanCard {
    name: string
    slug: string
    price: number
    interval?: string
    isFree: boolean
    hasTrial: boolean
    trialDuration?: number
    subtitle: string
    dataFeatures: { featureId?: string; label: string; value: string; detail?: string }[]
    platformFeatures: { label: string }[]
    ctaLabel: string
    ctaStyle: "outline" | "accent"
}

let plans: PlanCard[] = []

try {
    const autumn = new Autumn({ secretKey: import.meta.env.AUTUMN_SECRET_KEY })
    const result = await autumn.plans.list()

    if (result.list) {
        const products = result.list
            .filter((p) => !p.addOn)
            .sort((a, b) => {
                if (a.autoEnable && !b.autoEnable) return -1
                if (!a.autoEnable && b.autoEnable) return 1
                const priceA = a.price?.amount ?? 0
                const priceB = b.price?.amount ?? 0
                return priceA - priceB
            })

        plans = products.map((product) => {
            const isFree = product.autoEnable
            const slug = isFree ? "starter" : product.id?.toLowerCase() ?? product.name?.toLowerCase() ?? "startup"
            const price = isFree ? 0 : (product.price?.amount ?? 0)
            const interval = product.price?.interval

            const dataFeatures = product.items
                .filter((item) => item.featureId && !HIDDEN_FEATURE_IDS.has(item.featureId))
                .map((item) => ({
                    featureId: item.featureId,
                    label:
                        (item.featureId ? DATA_FEATURE_LABELS[item.featureId] : undefined) ??
                        item.feature?.name ??
                        item.featureId ??
                        "",
                    value: item.unlimited ? "Unlimited" : `${Number(item.included ?? 0)} GB`,
                    detail: item.price?.display?.secondaryText
                        ? item.price.display.secondaryText.replace(/\bper\s+(?:[\d,]+\s+)?(?:logs?|traces?|metrics?)\b/i, "per GB")
                        : item.price?.amount != null
                          ? `then $${item.price.amount} per GB`
                          : undefined,
                }))
                .sort((a, b) => dataFeatureRank(a.featureId) - dataFeatureRank(b.featureId))

            const platformFeatures = (PLAN_FEATURES[slug] ?? PLAN_FEATURES["startup"] ?? [])
                .map((f) => ({ label: f.label }))

            return {
                name: product.name,
                slug,
                price,
                interval: interval ? `/${interval}` : undefined,
                isFree,
                hasTrial: !!product.freeTrial,
                trialDuration: product.freeTrial?.durationLength,
                subtitle: isFree ? m.pricing_free_forever() : (product.description ?? (slug === "starter" ? m.pricing_for_small() : m.pricing_for_growing())),
                dataFeatures,
                platformFeatures,
                ctaLabel: isFree ? m.cta_get_started() : (product.freeTrial ? m.pricing_start_trial({ duration: String(product.freeTrial.durationLength) }) : m.pricing_subscribe()),
                ctaStyle: isFree ? "outline" as const : "accent" as const,
            }
        })
    }
} catch (e) {
    console.error("Failed to fetch pricing from Autumn:", e)
}

// Fallback if fetch fails
if (plans.length === 0) {
    plans = [
        {
            name: "Startup",
            slug: "startup",
            price: 39,
            interval: "/month",
            isFree: false,
            hasTrial: true,
            trialDuration: 14,
            subtitle: m.pricing_for_growing(),
            dataFeatures: [
                { featureId: "logs", label: m.pricing_logs(), value: "100 GB", detail: "then $0.25 per GB" },
                { featureId: "traces", label: m.pricing_traces(), value: "100 GB", detail: "then $0.25 per GB" },
                { featureId: "metrics", label: m.pricing_metrics(), value: "100 GB", detail: "then $0.25 per GB" },
            ],
            platformFeatures: PLAN_FEATURES["startup"]!.map((f) => ({ label: f.label })),
            ctaLabel: m.pricing_start_trial({ duration: "14" }),
            ctaStyle: "accent",
        },
    ]
}

// Enterprise renders as a peer card alongside the paid plan(s), so the grid is
// always balanced: one paid plan + Enterprise = a clean two-up; a second paid
// plan would make it a three-up. No lonely half-width card.
const cardCount = plans.length + 1
const gridClass =
    cardCount >= 3
        ? "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
        : "grid grid-cols-1 sm:grid-cols-2 gap-4"
const maxWidthClass = cardCount >= 3 ? "max-w-6xl" : "max-w-3xl"
---

<section class="py-16 md:py-24">
    <div class={`mx-auto ${maxWidthClass} px-6`}>
        <div class={gridClass}>
            {plans.map((plan) => (
                <div class="rounded-xl border border-border bg-bg-elevated flex flex-col">
                    <div class="p-6 md:p-8 flex flex-col flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-[11px] uppercase tracking-widest text-fg-muted">{plan.name}</span>
                            {plan.hasTrial && plan.trialDuration && (
                                <span class="inline-flex items-center rounded-full bg-accent/10 px-2 py-0.5 text-[10px] font-medium text-accent">
                                    {m.pricing_trial_badge({ duration: String(plan.trialDuration) })}
                                </span>
                            )}
                        </div>
                        <div class="mt-2 text-4xl font-semibold text-fg">
                            ${plan.price}
                            {plan.interval && <span class="text-base font-normal text-fg-muted">{plan.interval}</span>}
                        </div>
                        <p class="mt-1 text-sm text-fg-muted">{plan.subtitle}</p>

                        <div class="mt-6">
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted/70">{m.pricing_data_included()}</span>
                            <div class="mt-3 space-y-3">
                                {plan.dataFeatures.map((feature) => (
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            {feature.featureId === "logs" && (
                                                <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                                            )}
                                            {feature.featureId === "traces" && (
                                                <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                                            )}
                                            {feature.featureId === "metrics" && (
                                                <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 5 5-6"/></svg>
                                            )}
                                            <span class="text-sm text-fg">{feature.label}</span>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-sm text-fg-muted font-mono">{feature.value}</span>
                                            {feature.detail && (
                                                <p class="text-xs text-fg-muted/70 font-mono mt-0.5">{feature.detail}</p>
                                            )}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="my-6 h-px bg-border"></div>

                        <div>
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted/70">{m.pricing_platform_features()}</span>
                            <div class="mt-3 space-y-2.5">
                                {plan.platformFeatures.map((feature) => (
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                        <span class="text-sm text-fg-muted">{feature.label}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="mt-auto pt-8 space-y-2">
                            {plan.ctaStyle === "accent" ? (
                                <a href="https://app.maple.dev" class="flex h-9 w-full items-center justify-center rounded-lg bg-primary px-3 text-xs font-medium text-primary-foreground transition-all hover:bg-primary/80">
                                    {plan.ctaLabel}
                                </a>
                            ) : (
                                <a href="https://app.maple.dev" class="flex h-9 w-full items-center justify-center rounded-lg border border-input bg-input/30 px-3 text-xs font-medium text-fg transition-all hover:bg-input/50">
                                    {plan.ctaLabel}
                                </a>
                            )}
                            {plan.hasTrial && plan.trialDuration && (
                                <p class="text-[11px] text-fg-muted text-center">
                                    {m.pricing_trial_notice({ duration: String(plan.trialDuration) })}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            ))}
                <!-- Enterprise (peer card) -->
                <div class="rounded-xl border border-primary/20 bg-accent/[0.03] flex flex-col">
                    <div class="p-6 md:p-8 flex flex-col flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-[11px] uppercase tracking-widest text-fg-muted">{m.pricing_enterprise()}</span>
                        </div>
                        <div class="mt-2 text-4xl font-semibold text-fg">{m.pricing_custom()}</div>
                        <p class="mt-1 text-sm text-fg-muted">{m.pricing_enterprise_desc()}</p>

                        <div class="mt-6">
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted/70">{m.pricing_data_included()}</span>
                            <div class="mt-3 space-y-3">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                                        <span class="text-sm text-fg">{m.pricing_logs()}</span>
                                    </div>
                                    <span class="text-sm text-fg-muted font-mono">{m.pricing_custom()}</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                                        <span class="text-sm text-fg">{m.pricing_traces()}</span>
                                    </div>
                                    <span class="text-sm text-fg-muted font-mono">{m.pricing_custom()}</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 5 5-6"/></svg>
                                        <span class="text-sm text-fg">{m.pricing_metrics()}</span>
                                    </div>
                                    <span class="text-sm text-fg-muted font-mono">{m.pricing_custom()}</span>
                                </div>
                            </div>
                        </div>

                        <div class="my-6 h-px bg-border"></div>

                        <div>
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted/70">{m.pricing_platform_features()}</span>
                            <div class="mt-3 space-y-2.5">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_custom_retention()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_unlimited_dashboards()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_enterprise_alerting()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_mcp_server()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_ai_chat()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_ai_triage()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_full_api()}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                                    <span class="text-sm text-fg-muted">{m.pricing_priority_support()}</span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-auto pt-8">
                            <a href="https://cal.com/david-granzin/30min?overlayCalendar=true" class="flex h-9 w-full items-center justify-center rounded-lg border border-input bg-input/30 px-3 text-xs font-medium text-fg transition-all hover:bg-input/50">
                                {m.pricing_talk_to_founder()}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
    </div>
</section>
