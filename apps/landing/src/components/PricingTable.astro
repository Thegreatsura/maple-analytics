---
import { Autumn } from "autumn-js"
import * as m from "../paraglide/messages";

const HIDDEN_FEATURE_IDS = new Set<string>(["ai_input_tokens", "ai_output_tokens"])

// Capitalized, localized labels for the metered data rows, keyed by Autumn
// featureId (Autumn returns lowercase names like "logs"). Drives the row text;
// the icon is matched on featureId in the template.
const DATA_FEATURE_LABELS: Record<string, string> = {
    logs: m.pricing_logs(),
    traces: m.pricing_traces(),
    metrics: m.pricing_metrics(),
    browser_sessions: m.nav_browser_sessions(),
}

// Canonical row order so the plan card matches the Enterprise card (Autumn can
// return items in any order).
const DATA_FEATURE_ORDER = ["logs", "traces", "metrics", "browser_sessions"]
const dataFeatureRank = (id: string | undefined) => {
    const i = id ? DATA_FEATURE_ORDER.indexOf(id) : -1
    return i === -1 ? DATA_FEATURE_ORDER.length : i
}

// Full platform feature list per plan, rendered inside each card. The list is
// the perceived-value signal on a pricing page — each card should visibly carry
// everything it includes. Differentiators (retention, support) lead the list so
// the plan-to-plan difference is scannable at the top.
const PLAN_FEATURES: Record<string, string[]> = {
    starter: [
        m.pricing_14day_retention(),
        m.pricing_email_support(),
        m.pricing_unlimited_dashboards(),
        m.pricing_advanced_alerting(),
        m.pricing_mcp_server(),
        m.pricing_ai_chat(),
        m.pricing_ai_triage(),
        m.pricing_full_api(),
    ],
    startup: [
        m.pricing_30day_retention(),
        m.pricing_private_channel(),
        m.pricing_unlimited_dashboards(),
        m.pricing_advanced_alerting(),
        m.pricing_mcp_server(),
        m.pricing_ai_chat(),
        m.pricing_ai_triage(),
        m.pricing_full_api(),
    ],
}

interface PlanCard {
    name: string
    slug: string
    price: number
    priceLabel?: string
    interval?: string
    isFree: boolean
    hasTrial: boolean
    trialDuration?: number
    subtitle: string
    dataFeatures: { featureId?: string; label: string; value: string; detail?: string }[]
    platformFeatures: string[]
    ctaLabel: string
    ctaHref: string
    ctaStyle: "outline" | "accent"
}

let plans: PlanCard[] = []

try {
    const autumn = new Autumn({ secretKey: import.meta.env.AUTUMN_SECRET_KEY })
    const result = await autumn.plans.list()

    if (result.list) {
        const products = result.list
            .filter((p) => !p.addOn)
            .sort((a, b) => {
                if (a.autoEnable && !b.autoEnable) return -1
                if (!a.autoEnable && b.autoEnable) return 1
                const priceA = a.price?.amount ?? 0
                const priceB = b.price?.amount ?? 0
                return priceA - priceB
            })

        plans = products.map((product) => {
            const isFree = product.autoEnable
            const slug = isFree ? "starter" : product.id?.toLowerCase() ?? product.name?.toLowerCase() ?? "startup"
            const price = isFree ? 0 : (product.price?.amount ?? 0)
            const interval = product.price?.interval

            const dataFeatures = product.items
                .filter((item) => item.featureId && !HIDDEN_FEATURE_IDS.has(item.featureId))
                .map((item) => ({
                    featureId: item.featureId,
                    label:
                        (item.featureId ? DATA_FEATURE_LABELS[item.featureId] : undefined) ??
                        item.feature?.name ??
                        item.featureId ??
                        "",
                    // browser_sessions is metered by count, not bytes — everything else is GB.
                    value: item.unlimited
                        ? "Unlimited"
                        : item.featureId === "browser_sessions"
                          ? `${Number(item.included ?? 0).toLocaleString()} sessions`
                          : `${Number(item.included ?? 0)} GB`,
                    detail: item.price?.display?.secondaryText
                        ? item.price.display.secondaryText.replace(/\bper\s+(?:[\d,]+\s+)?(?:logs?|traces?|metrics?)\b/i, "per GB")
                        : item.price?.amount != null
                          ? item.featureId === "browser_sessions"
                            ? `then $${item.price.amount} per 1,000 sessions`
                            : `then $${item.price.amount} per GB`
                          : undefined,
                }))
                .sort((a, b) => dataFeatureRank(a.featureId) - dataFeatureRank(b.featureId))

            const platformFeatures = PLAN_FEATURES[slug] ?? PLAN_FEATURES["startup"] ?? []

            return {
                name: product.name,
                slug,
                price,
                interval: interval ? `/${interval}` : undefined,
                isFree,
                hasTrial: !!product.freeTrial,
                trialDuration: product.freeTrial?.durationLength,
                subtitle: isFree ? m.pricing_free_forever() : (product.description ?? (slug === "starter" ? m.pricing_for_small() : m.pricing_for_growing())),
                dataFeatures,
                platformFeatures,
                ctaLabel: isFree ? m.cta_get_started() : (product.freeTrial ? m.pricing_start_trial({ duration: String(product.freeTrial.durationLength) }) : m.pricing_subscribe()),
                ctaHref: "https://app.maple.dev",
                ctaStyle: isFree ? "outline" as const : "accent" as const,
            }
        })
    }
} catch (e) {
    console.error("Failed to fetch pricing from Autumn:", e)
}

// Fallback if fetch fails
if (plans.length === 0) {
    plans = [
        {
            name: "Startup",
            slug: "startup",
            price: 39,
            interval: "/month",
            isFree: false,
            hasTrial: true,
            trialDuration: 14,
            subtitle: m.pricing_for_growing(),
            dataFeatures: [
                { featureId: "logs", label: m.pricing_logs(), value: "100 GB", detail: "then $0.25 per GB" },
                { featureId: "traces", label: m.pricing_traces(), value: "100 GB", detail: "then $0.25 per GB" },
                { featureId: "metrics", label: m.pricing_metrics(), value: "100 GB", detail: "then $0.25 per GB" },
            ],
            platformFeatures: PLAN_FEATURES["startup"]!,
            ctaLabel: m.pricing_start_trial({ duration: "14" }),
            ctaHref: "https://app.maple.dev",
            ctaStyle: "accent",
        },
    ]
}

// Enterprise is a peer card, modelled in the same shape as the self-serve plans
// so it flows through the same grid + card template (no duplicated markup) and
// stays visually equal — different role, not a highlighted upsell. It carries
// the full feature set too, leading with its differentiators.
const enterprisePlan: PlanCard = {
    name: m.pricing_enterprise(),
    slug: "enterprise",
    price: 0,
    priceLabel: m.pricing_enterprise_price(),
    isFree: false,
    hasTrial: false,
    subtitle: m.pricing_enterprise_desc(),
    dataFeatures: [
        { featureId: "logs", label: m.pricing_logs(), value: m.pricing_custom() },
        { featureId: "traces", label: m.pricing_traces(), value: m.pricing_custom() },
        { featureId: "metrics", label: m.pricing_metrics(), value: m.pricing_custom() },
        { featureId: "browser_sessions", label: m.nav_browser_sessions(), value: m.pricing_custom() },
    ],
    platformFeatures: [
        m.pricing_custom_retention(),
        m.pricing_priority_support(),
        m.pricing_otel_data_help(),
        m.pricing_unlimited_dashboards(),
        m.pricing_advanced_alerting(),
        m.pricing_mcp_server(),
        m.pricing_ai_chat(),
        m.pricing_ai_triage(),
        m.pricing_full_api(),
    ],
    ctaLabel: m.pricing_talk_to_founder(),
    ctaHref: "https://cal.com/david-granzin/30min?overlayCalendar=true",
    ctaStyle: "outline",
}

const cards: PlanCard[] = [...plans, enterprisePlan]

// Equal-peer grid: stack until lg, then go N-up — no sm 2-up state that would
// orphan a third card onto a lonely second row. Two cards stay a clean 2-up.
const gridClass =
    cards.length >= 3
        ? "grid grid-cols-1 lg:grid-cols-3 gap-4"
        : "grid grid-cols-1 sm:grid-cols-2 gap-4"
const maxWidthClass = cards.length >= 3 ? "max-w-6xl" : "max-w-4xl"
---

<section class="py-20 md:py-28">
    <div class={`mx-auto ${maxWidthClass} px-6`}>
        <div class={gridClass}>
            {cards.map((plan) => (
                <div class="rounded-xl border border-border bg-bg-elevated flex flex-col">
                    <div class="p-6 md:p-8 flex flex-col flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-[11px] uppercase tracking-widest text-fg-muted">{plan.name}</span>
                            {plan.hasTrial && plan.trialDuration && (
                                <span class="inline-flex items-center rounded-full bg-accent/10 px-2 py-0.5 text-[10px] font-medium text-accent">
                                    {m.pricing_trial_badge({ duration: String(plan.trialDuration) })}
                                </span>
                            )}
                        </div>

                        <div class="mt-3 flex items-baseline gap-1 text-4xl font-semibold text-fg tracking-tight">
                            {plan.priceLabel ? (
                                <span class="text-3xl">{plan.priceLabel}</span>
                            ) : (
                                <>
                                    <span class="font-mono tabular-nums">${plan.price}</span>
                                    {plan.interval && <span class="text-base font-normal text-fg-muted">{plan.interval}</span>}
                                </>
                            )}
                        </div>
                        <p class="mt-2 text-sm text-fg-muted leading-relaxed">{plan.subtitle}</p>

                        {/* Data allotments — the differentiating, usage-based numbers get the card's visual weight. */}
                        <div class="mt-8">
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted">{m.pricing_data_included()}</span>
                            <div class="mt-4 space-y-4">
                                {plan.dataFeatures.map((feature) => (
                                    <div class="flex items-start justify-between gap-3">
                                        <div class="flex items-center gap-2 pt-0.5">
                                            {feature.featureId === "logs" && (
                                                <svg class="w-4 h-4 text-fg-muted shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M8 18H16"/><path d="M8 14L11 14"/><path d="M12 4V10H8"/><path d="M4 20L4 10"/><path d="M20 20L20 4"/><path d="M12 2L18 2"/><path d="M6 22L18 22"/><path d="M6 8H6.01"/><path d="M8 6H8.01"/><path d="M10 4H10.01"/></svg>
                                            )}
                                            {feature.featureId === "traces" && (
                                                <svg class="w-4 h-4 text-fg-muted shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M6 18.01L6 18"/><path d="M18 7.01001L18 7.00001"/><path d="M8 20.01L8 20"/><path d="M2 16L4 16"/><path d="M14 9L16 9"/><path d="M20 5L22 5"/><path d="M10 16L10 18"/><path d="M12 11L12 14"/></svg>
                                            )}
                                            {feature.featureId === "metrics" && (
                                                <svg class="w-4 h-4 text-fg-muted shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M2 15.01V15"/><path d="M4 13.01V13"/><path d="M6 11.01V11"/><path d="M8 9.01V9"/><path d="M10 11.01V11"/><path d="M12 13.01V13"/><path d="M14 15.01V15"/><path d="M16 13.01V13"/><path d="M18 11.01V11"/><path d="M20 9.01V9"/><path d="M22 7.01V7"/></svg>
                                            )}
                                            {feature.featureId === "browser_sessions" && (
                                                <svg class="w-4 h-4 text-fg-muted shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M4 6L4 6.01"/><path d="M6 4L6 4.01"/><path d="M20.01 6L20 6"/><path d="M18.01 4L18 4"/><path d="M20.01 18L20 18"/><path d="M18.01 20L18 20"/><path d="M6.01001 20L6.00001 20"/><path d="M4.01001 18L4.00001 18"/><path d="M2 8L2 16"/><path d="M22 14L22 16"/><path d="M8 2L16 2"/><path d="M8 22L16 22"/><path d="M22 8V4"/><path d="M17 12.01V12"/><path d="M14 10H15"/><path d="M14 14H15"/><path d="M12 8H9L9 16L12 16"/></svg>
                                            )}
                                            <span class="text-sm text-fg">{feature.label}</span>
                                        </div>
                                        <div class="text-right">
                                            <div class="font-mono tabular-nums text-base text-fg leading-none">{feature.value}</div>
                                            {feature.detail && (
                                                <div class="mt-1.5 font-mono text-xs text-fg-muted">{feature.detail}</div>
                                            )}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        {/* Full feature list — the visible "everything you get" value signal. */}
                        <div class="mt-6 border-t border-border pt-6">
                            <span class="text-[10px] uppercase tracking-widest text-fg-muted">{m.pricing_platform_features()}</span>
                            <div class="mt-4 space-y-3">
                                {plan.platformFeatures.map((label) => (
                                    <div class="flex items-center gap-2.5">
                                        <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M8 2L16 2"/><path d="M8 22L16 22"/><path d="M2 8L2 16"/><path d="M22 8L22 16"/><path d="M6 4L6 4.01"/><path d="M4 6L4 6.01"/><path d="M18 4L18 4.01"/><path d="M20 6L20 6.01"/><path d="M6 20L6 20.01"/><path d="M4 18L4 18.01"/><path d="M18 20L18 20.01"/><path d="M20 18L20 18.01"/><path d="M8 12L11 15L16 9"/></svg>
                                        <span class="text-sm text-fg">{label}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="mt-auto pt-8 space-y-2">
                            {plan.ctaStyle === "accent" ? (
                                <a href={plan.ctaHref} class="flex h-9 w-full items-center justify-center rounded-lg bg-primary px-3 text-xs font-medium text-primary-foreground transition-all hover:bg-primary/80">
                                    {plan.ctaLabel}
                                </a>
                            ) : (
                                <a href={plan.ctaHref} class="flex h-9 w-full items-center justify-center rounded-lg border border-input bg-input/30 px-3 text-xs font-medium text-fg transition-all hover:bg-input/50">
                                    {plan.ctaLabel}
                                </a>
                            )}
                            {plan.hasTrial && plan.trialDuration && (
                                <p class="text-[11px] text-fg-muted text-center">
                                    {m.pricing_trial_notice({ duration: String(plan.trialDuration) })}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
