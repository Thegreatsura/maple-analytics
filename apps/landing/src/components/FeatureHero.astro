---
import { buttonVariants } from "@maple/ui/components/ui/button";
import { HeroCta } from "./HeroCta";

interface Props {
    label: string;
    title: string;
    subtitle: string;
}

const { label, title, subtitle } = Astro.props;
---

<section class="relative pt-[19px] overflow-hidden">
    <!-- Grid background -->
    <div class="absolute inset-0 pointer-events-none" style="
        background-image:
            linear-gradient(to right, oklch(1 0 0 / 4%) 1px, transparent 1px),
            linear-gradient(to bottom, oklch(1 0 0 / 4%) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black, transparent);
    "></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-24 md:pt-32 pb-16 md:pb-24">
        <!-- Badge -->
        <div class="mb-6">
            <span class="inline-flex items-center rounded-full border border-border bg-card px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-primary">
                {label}
            </span>
        </div>

        <!-- Headline -->
        <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-fg leading-tight max-w-3xl tracking-tight">
            {title}
        </h1>

        <!-- Subtitle -->
        <p class="mt-5 text-sm md:text-base text-fg-muted max-w-2xl leading-relaxed">
            {subtitle}
        </p>

        <!-- Dual CTAs -->
        <div class="mt-8 flex flex-wrap items-center gap-3">
            <HeroCta client:load className={buttonVariants({ size: "default" })} />
            <a href="https://github.com/Makisuo/maple" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "outline", size: "default" })}>
                View on GitHub
            </a>
        </div>
    </div>
</section>
