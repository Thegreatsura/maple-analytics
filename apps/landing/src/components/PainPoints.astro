---
interface Props {
    competitorName: string;
    painPoints: Array<{ problem: string; solution: string }>;
}

const { competitorName, painPoints } = Astro.props;
---

<section class="py-24 md:py-32">
    <div class="mx-auto max-w-5xl px-6">
        <div class="mb-10">
            <span class="inline-block border border-border px-3 py-1 text-[11px] text-accent uppercase tracking-wider mb-4">
                Common challenges
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-fg">
                Problems with {competitorName} that Maple solves
            </h2>
        </div>

        <div class="space-y-px border border-border">
            {painPoints.map(point => (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
                    <div class="bg-bg p-6 md:p-8 flex gap-4">
                        <div class="shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 6L6 18M6 6l12 12"/>
                            </svg>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase tracking-wider text-fg-muted block mb-1.5">{competitorName}</span>
                            <p class="text-sm text-fg-muted leading-relaxed">{point.problem}</p>
                        </div>
                    </div>
                    <div class="bg-bg p-6 md:p-8 flex gap-4">
                        <div class="shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase tracking-wider text-accent block mb-1.5">Maple</span>
                            <p class="text-sm text-fg leading-relaxed">{point.solution}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
