---
import { getRelativeLocaleUrl } from "astro:i18n";
import * as m from "../paraglide/messages";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const locale = Astro.currentLocale ?? "en";
const l = (path: string) => getRelativeLocaleUrl(locale, path);
---

<footer class="border-t border-border">
    <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
            <!-- Col 1: Logo + tagline -->
            <div class="col-span-2 md:col-span-3 lg:col-span-2">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-6 h-6 bg-accent flex items-center justify-center">
                        <span class="text-accent-foreground text-[10px] font-bold">M</span>
                    </div>
                    <span class="text-fg text-xs font-medium">Maple</span>
                </div>
                <p class="text-fg-muted text-[10px] leading-relaxed max-w-xs">
                    {m.footer_tagline()}
                </p>
            </div>

            <!-- Col 2: Product -->
            <div>
                <h4 class="text-[11px] text-fg font-medium uppercase tracking-wider mb-4">{m.footer_product()}</h4>
                <ul class="space-y-2">
                    <li><a href={`${l("/")}#features`} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_features()}</a></li>
                    <li><a href={`${l("/")}#how-it-works`} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_how_it_works()}</a></li>
                    <li><a href={l("/pricing")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_pricing()}</a></li>
                    <li><a href={l("/opentelemetry")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_opentelemetry()}</a></li>
                    <li><a href={l("/roadmap")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_roadmap()}</a></li>
                    <li><a href="/docs" class="text-fg-muted text-xs hover:text-fg transition-colors">Docs</a></li>
                </ul>
            </div>

            <!-- Col 3: Features -->
            <div>
                <h4 class="text-[11px] text-fg font-medium uppercase tracking-wider mb-4">{m.footer_features()}</h4>
                <ul class="space-y-2">
                    <li><a href={l("/features/distributed-tracing")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_distributed_tracing()}</a></li>
                    <li><a href={l("/features/log-management")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_log_management()}</a></li>
                    <li><a href={l("/features/metrics-dashboards")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_metrics_dashboards()}</a></li>
                    <li><a href={l("/features/service-catalog")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_service_catalog()}</a></li>
                    <li><a href={l("/features/error-tracking")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_error_tracking()}</a></li>
                    <li><a href={l("/features/ai-mcp-integration")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_ai_mcp()}</a></li>
                </ul>
            </div>

            <!-- Col 4: Compare -->
            <div>
                <h4 class="text-[11px] text-fg font-medium uppercase tracking-wider mb-4">{m.footer_compare()}</h4>
                <ul class="space-y-2">
                    <li><a href={l("/compare/datadog")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_vs_datadog()}</a></li>
                    <li><a href={l("/compare/grafana")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_vs_grafana()}</a></li>
                    <li><a href={l("/compare/new-relic")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_vs_new_relic()}</a></li>
                </ul>

                <h4 class="text-[11px] text-fg font-medium uppercase tracking-wider mb-4 mt-6">{m.footer_integrations()}</h4>
                <ul class="space-y-2">
                    <li><a href={l("/integrations/nextjs")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.nav_nextjs()}</a></li>
                    <li><a href={l("/integrations/python")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.nav_python()}</a></li>
                    <li><a href={l("/integrations/nodejs")} class="text-fg-muted text-xs hover:text-fg transition-colors">{m.nav_nodejs()}</a></li>
                </ul>
            </div>

            <!-- Col 5: Community -->
            <div>
                <h4 class="text-[11px] text-fg font-medium uppercase tracking-wider mb-4">{m.footer_community()}</h4>
                <ul class="space-y-2">
                    <li><a href="https://github.com/Makisuo/maple" target="_blank" rel="noopener noreferrer" class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_github()}</a></li>
                    <li><a href="https://opentelemetry.io" target="_blank" rel="noopener noreferrer" class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_opentelemetry()}</a></li>
                    <li><a href="https://x.com/maple_dev" target="_blank" rel="noopener noreferrer" class="text-fg-muted text-xs hover:text-fg transition-colors">{m.footer_twitter()}</a></li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-12 pt-6 border-t border-border flex flex-col sm:flex-row items-center sm:justify-between gap-4">
            <p class="text-fg-muted text-[10px]">&copy; {m.footer_copyright()}</p>
            <div class="flex items-center gap-4">
                <a href={l("/privacy")} class="text-fg-muted text-[10px] hover:text-fg transition-colors">{m.footer_privacy()}</a>
                <a href={l("/terms")} class="text-fg-muted text-[10px] hover:text-fg transition-colors">{m.footer_terms()}</a>
                <LanguageSwitcher />
            </div>
        </div>
    </div>
</footer>
