---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Competitor } from "../lib/competitors";

interface Props {
    currentSlug: string;
    competitors: Record<string, Competitor>;
}

const { currentSlug, competitors } = Astro.props;
const locale = Astro.currentLocale ?? "en";
const l = (path: string) => getRelativeLocaleUrl(locale, path);

const otherCompetitors = Object.values(competitors).filter(c => c.slug !== currentSlug);
---

<section class="py-24 md:py-32">
    <div class="mx-auto max-w-5xl px-6">
        <div class="mb-10">
            <span class="inline-flex items-center rounded-full border border-border bg-card px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-primary mb-4">
                Compare
            </span>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-fg tracking-tight">Other comparisons</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border border border-border">
            {otherCompetitors.map(comp => (
                <a href={l(`/compare/${comp.slug}`)} class="bg-bg p-6 md:p-8 group hover:bg-primary/5 transition-colors">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-base font-semibold text-fg">Maple vs {comp.name}</h3>
                        <svg class="w-4 h-4 text-fg-muted group-hover:text-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                    <p class="text-sm text-fg-muted leading-relaxed">{comp.tagline}</p>
                </a>
            ))}
        </div>
    </div>
</section>
