---
import type { BlogCategory } from "../../lib/blog";
import type { PixelIconName } from "./pixel-icons";
import PixelIcon from "./PixelIcon.astro";
import PixelIconField from "./PixelIconField.astro";

interface Props {
    title: string;
    category?: BlogCategory;
    cover?: string;
    coverAlt?: string;
    variant?: "card" | "featured" | "banner";
    drench?: boolean;
    class?: string;
}

const { title, category, cover, coverAlt, variant = "card", drench, class: className = "" } = Astro.props;

// Focal pixel glyph per category — the hero of the generated cover art.
const FOCAL: Record<string, PixelIconName> = {
    engineering: "activity",
    guides: "trend",
    product: "gauge",
    company: "globe",
};
const focal: PixelIconName = (category && FOCAL[category]) || "window";
const isDrench = drench ?? variant === "featured";
const eager = variant === "featured" || variant === "banner";

const aspect =
    variant === "banner"
        ? "aspect-[16/9] md:aspect-[5/2]"
        : variant === "featured"
          ? "aspect-[16/10] md:h-full"
          : "aspect-[16/9]";

// Icon tint follows the cover surface.
const tint = isDrench ? "text-primary-foreground" : "text-primary";
const focalClass = [
    "pointer-events-none absolute right-[3%] -top-[4%] aspect-square h-[64%]",
    tint,
    isDrench ? "opacity-[0.16]" : "opacity-[0.13]",
].join(" ");
---

{cover ? (
    <div class:list={["relative overflow-hidden", aspect, className]}>
        <img
            src={cover}
            alt={coverAlt ?? `Cover image for ${title}`}
            loading={eager ? "eager" : "lazy"}
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover"
        />
    </div>
) : (
    <div
        class:list={[
            "relative flex items-end overflow-hidden p-4",
            aspect,
            // No `bg-*` on the drench element so the global .drenched-amber background wins.
            isDrench ? "drenched-amber text-primary-foreground" : "bg-bg-deep",
            className,
        ]}
        role="img"
        aria-label={`Cover graphic for ${title}`}
    >
        {/* Ambient telemetry texture */}
        <PixelIconField class={tint} />

        {/* Focal glyph */}
        <PixelIcon name={focal} class={focalClass} />

        {/* Terminal prompt */}
        <span class="relative z-[2] inline-flex items-center gap-[7px] font-mono text-[11px] tracking-[0.02em]" aria-hidden="true">
            <span class:list={[isDrench ? "text-primary-foreground/60" : "text-fg-muted"]}>~/maple/blog</span>
            <span class:list={[isDrench ? "text-primary-foreground" : "text-primary"]}>$</span>
            <span class:list={[isDrench ? "text-primary-foreground/90" : "text-fg/80"]}>cat {category ?? "post"}</span>
            <span
                class:list={[
                    "inline-block h-[11px] w-[6px] motion-safe:animate-pulse",
                    isDrench ? "bg-primary-foreground" : "bg-primary",
                ]}
            ></span>
        </span>
    </div>
)}
