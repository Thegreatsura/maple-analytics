---
import { buttonVariants } from "@maple/ui/components/ui/button";
import AppMock from './AppMock.astro';
import * as m from "../paraglide/messages";
import { HeroCta } from "./HeroCta";
import { DATA_POINTS_INGESTED, formatDataPoints } from "../lib/ingest-stats";
import { getGitHubStars, formatStars } from "../lib/github-stars";
import PixelStar from "./icons/PixelStar.astro";

const stars = await getGitHubStars();
---

<section class="relative min-h-screen pt-[19px] overflow-hidden">
    <!-- Grid background -->
    <div class="absolute inset-0 pointer-events-none" style="
        background-image:
            linear-gradient(to right, oklch(1 0 0 / 4%) 1px, transparent 1px),
            linear-gradient(to bottom, oklch(1 0 0 / 4%) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black, transparent);
    "></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-24 md:pt-32">
        <!-- Badge -->
        <div class="mb-7">
            <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-[0.14em] text-fg-muted">
                <span class="inline-block size-1.5 rounded-full bg-primary animate-pulse-dot"></span>
                {m.hero_badge()}
            </span>
        </div>

        <!-- Headline -->
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold text-fg leading-[1.02] max-w-4xl tracking-[-0.02em]">
            {m.hero_title()}<br />
            {m.hero_title_sub()} <span class="text-gradient-accent">{m.hero_title_accent()}</span>
        </h1>

        <!-- Subtitle -->
        <p class="mt-6 text-base md:text-lg text-fg-muted max-w-xl leading-relaxed">
            {m.hero_subtitle()}
        </p>

        <!-- Dual CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
            <HeroCta client:load className={buttonVariants({ size: "xl" })} />
            <a href="https://github.com/Makisuo/maple" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "outline", size: "xl" })}>
                {m.cta_github()}
            </a>
        </div>

        <!-- Credibility stat row: number over a quiet label, split by a hairline
             divider. GitHub stars are live (build-time fetch); the ingest figure
             is the hardcoded platform total. -->
        <div class="mt-12 flex items-stretch border-t border-border pt-8">
            {stars !== null && (
                <a
                    href="https://github.com/Makisuo/maple"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex flex-col gap-2 pr-8 md:pr-12"
                >
                    <span class="font-display text-3xl md:text-4xl font-semibold text-fg tracking-tight tabular-nums transition-colors group-hover:text-primary">
                        {formatStars(stars)}
                    </span>
                    <span class="inline-flex items-center gap-1.5 text-sm text-fg-muted transition-colors group-hover:text-fg">
                        <PixelStar class="size-4 text-primary" />
                        {m.stat_github()}
                    </span>
                </a>
            )}
            <div class={`flex flex-col gap-2 ${stars !== null ? "border-l border-border pl-8 md:pl-12" : ""}`}>
                <span class="font-display text-3xl md:text-4xl font-semibold text-fg tracking-tight tabular-nums">
                    {formatDataPoints(DATA_POINTS_INGESTED)}+
                </span>
                <span class="text-sm text-fg-muted">{m.ingest_stats_label()}</span>
            </div>
        </div>

        <!-- App mock with glow -->
        <div class="mt-16 md:mt-20 relative">
            <div class="absolute inset-0 pointer-events-none" style="
                box-shadow: 0 0 120px 40px oklch(0.70 0.16 60 / 0.08);
            "></div>
            <AppMock />
        </div>
    </div>
</section>
