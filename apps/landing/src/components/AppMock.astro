    { id: "3fd5d93c", method: "PUT",  path: "/api/orders/confirm",  at: "Jul 14, 06:43:05 PM (20s ago)", services: ["checkout-api"],            dur: "156.0ms", status: "200" },
];
const methodChip: Record<string, string> = {
    GET: "bg-severity-debug text-background",
    POST: "bg-primary text-primary-foreground",
    PUT: "bg-severity-info text-background",
};

interface LogRow { level: "INFO" | "WARN" | "ERROR" | "DEBUG"; at: string; svc: string; msg: string }
const logRows: LogRow[] = [
    { level: "INFO",  at: "18:40:44.931", svc: "checkout-api", msg: "POST /api/checkout 200 203ms" },
    { level: "INFO",  at: "18:40:44.898", svc: "checkout-api", msg: 'Order created order_id=ord_8f3a2c' },
    { level: "WARN",  at: "18:40:44.835", svc: "payments",     msg: "Retry attempt 2/3 for charge txn_9d1e" },
    { level: "ERROR", at: "18:40:44.755", svc: "payments",     msg: "Connection timeout to stripe after 5000ms" },
    { level: "INFO",  at: "18:40:44.752", svc: "auth-svc",     msg: "Token validated user_id=usr_2f8a" },
    { level: "DEBUG", at: "18:40:44.694", svc: "edge",         msg: "Rate limit check passed ip=192.168.1.42" },
    { level: "INFO",  at: "18:40:44.688", svc: "pricing",      msg: "Stock reserved sku=SKU-1234 qty=2" },
];
const levelText: Record<string, string> = {
    INFO: "text-severity-info",
    WARN: "text-severity-warn",
    ERROR: "text-severity-error",
    DEBUG: "text-severity-debug",
};
const levelDot: Record<string, string> = {
    INFO: "bg-severity-info",
    WARN: "bg-severity-warn",
    ERROR: "bg-severity-error",
    DEBUG: "bg-severity-debug",
};

// Stacked log histogram: [info, warn, error] heights in % (sums stay < 100)
const logBars: Array<[number, number, number]> = [
    [42, 10, 3], [48, 12, 4], [40, 9, 3], [52, 11, 5], [46, 10, 4], [58, 14, 4],
    [44, 10, 3], [50, 12, 16], [47, 11, 5], [43, 9, 3], [55, 13, 4], [49, 11, 4],
    [45, 10, 3], [53, 12, 5], [48, 10, 4], [44, 9, 3], [57, 13, 5], [50, 11, 4],
    [46, 10, 3], [52, 12, 4], [48, 11, 4], [45, 9, 3], [54, 12, 5], [49, 10, 4],
];

interface ServiceRow { name: string; ns?: string; p50: string; p95: string; p99: string; err: string; hot?: boolean; spark: number[] }
const serviceRows: ServiceRow[] = [
    { name: "edge",         ns: "gateway",  p50: "3.1ms",  p95: "9.4ms",   p99: "24.0ms",  err: "0.1%",  spark: [2, 3, 2, 4, 3, 2, 3, 2, 4, 3, 2, 3] },
    { name: "checkout-api", ns: "api",      p50: "12.0ms", p95: "45.3ms",  p99: "120.0ms", err: "0.3%",  spark: [3, 4, 3, 5, 4, 3, 6, 4, 3, 4, 3, 4] },
    { name: "auth-svc",     ns: "api",      p50: "2.4ms",  p95: "8.1ms",   p99: "22.0ms",  err: "0.0%",  spark: [1, 1, 2, 1, 1, 2, 1, 1, 1, 2, 1, 1] },
    { name: "pricing",      ns: "api",      p50: "34.0ms", p95: "142.0ms", p99: "480.0ms", err: "2.4%",  hot: true, spark: [4, 5, 6, 8, 12, 16, 13, 10, 12, 14, 11, 12] },
    { name: "payments",     ns: "worker",   p50: "56.0ms", p95: "145.0ms", p99: "380.0ms", err: "0.5%",  spark: [3, 4, 5, 4, 6, 5, 4, 5, 6, 5, 4, 5] },
    { name: "notifier",     ns: "worker",   p50: "5.0ms",  p95: "15.2ms",  p99: "42.0ms",  err: "0.0%",  spark: [1, 2, 1, 1, 2, 1, 2, 1, 1, 1, 2, 1] },
];
function sparkPoints(spark: number[]): string {
    const max = Math.max(...spark, 1);
    const w = 64;
    const h = 14;
    return spark
        .map((v, i) => `${((i / (spark.length - 1)) * w).toFixed(1)},${(h - 2 - (v / max) * (h - 4)).toFixed(1)}`)
        .join(" ");
}
