            <div class="flex items-center justify-between text-[9px] text-fg-muted">
                <div class="hidden md:flex items-center gap-3 min-w-0">
                    <span class="whitespace-nowrap">Drag nodes to arrange</span>
                    <span class="opacity-30">|</span>
                    <span class="whitespace-nowrap">Scroll to zoom</span>
                    <span class="opacity-30 hidden md:inline">|</span>
                    <span class="hidden md:inline-flex items-center gap-2.5 min-w-0">
                        {mapOrderedServices.slice(0, 3).map((label) => (
                            <span class="inline-flex items-center gap-1 whitespace-nowrap"><span class="size-1.5 rounded-full" style={`background-color: ${mapServiceColor(label)}`}></span>{label}</span>
                        ))}
                        <span class="whitespace-nowrap">+2 more</span>
                    </span>
                </div>
                <div class="flex items-center gap-2.5">
                    <span class="inline-flex items-center gap-1"><span class="size-1.5 rounded-full bg-severity-info"></span>Healthy</span>
                    <span class="inline-flex items-center gap-1"><span class="size-1.5 rounded-full bg-severity-warn"></span>Degraded</span>
                    <span class="inline-flex items-center gap-1"><span class="size-1.5 rounded-full bg-severity-error"></span>Error</span>
                </div>
            </div>
        </div>

        <!-- ===== OVERVIEW VIEW ===== -->
        <div class="mock-view mock-view-overview flex-1 p-3 md:p-4 space-y-2.5 overflow-hidden max-md:max-h-[440px] max-md:overflow-y-auto max-md:overscroll-y-contain">
            <!-- Page header -->
            <div class="flex items-end justify-between gap-2">
                <div>
                    <div class="font-display text-sm md:text-base text-fg font-semibold leading-tight">Dashboard</div>
                    <div class="text-[9px] text-fg-muted">Observability overview for your services.</div>
                </div>
                <div class="flex items-center gap-1.5 shrink-0">
                    <span class="hidden sm:inline-flex items-center gap-1 rounded-lg border border-border px-2 py-0.5 text-[9px] text-fg">production
                        <svg class="w-2 h-2 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
                    </span>
                    <span class="inline-flex items-center gap-1 whitespace-nowrap rounded-lg border border-border px-2 py-0.5 text-[9px] text-fg">
                        <svg class="w-2.5 h-2.5 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Last 24 hours
                    </span>
                </div>
            </div>
            <!-- Alert status strip -->
            <div class="flex items-center gap-2 rounded-lg border border-border bg-bg px-3 py-1.5">
                <span class="size-1.5 rounded-full bg-severity-info"></span>
                <span class="text-[10px] text-fg font-medium">All clear</span>
                <span class="text-[10px] text-fg-muted">/ 4 rules watching</span>
            </div>
            <!-- Health strip: Services · Healthy · Degraded · Unhealthy -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border border border-border rounded-lg overflow-hidden">
                <div class="bg-bg-elevated px-2.5 py-1.5">
                    <div class="text-[8px] text-fg-muted">Services</div>
                    <div class="text-sm text-fg font-bold">22</div>
