                                                </svg>
                                            )}
                                            {n.platform === "lambda" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#FF9900" class="shrink-0" aria-hidden="true">
                                                    <path d="M3.6722 3v17.997h4.5066l1.6512-3.4192H6.563V6.4192h2.4119L7.4036 3zm10.5418 0L9.749 12.0146l4.4642 8.9854H21l-4.4856-9.0145L20.917 3z" />
                                                </svg>
                                            )}
                                            {n.dbSystem === "postgres" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4169E1" class="shrink-0" aria-hidden="true">
                                                    <path d="M23.5594 14.7228a.5269.5269 0 0 0-.0563-.1191c-.139-.2632-.4768-.3418-1.0074-.2321-1.6533.3411-2.2935.1312-2.5256-.0191 1.342-2.0482 2.445-4.522 3.0411-6.8297.2714-1.0507.7982-3.5237.1222-4.7316a1.5641 1.5641 0 0 0-.1509-.235C21.6931.9086 19.8007.0248 17.5099.0005c-1.4947-.0158-2.7705.3461-3.1161.4794a9.449 9.449 0 0 0-.5159-.0816 8.044 8.044 0 0 0-1.3114-.1278c-1.1822-.0184-2.2038.2642-3.0498.8406-.8573-.3211-4.7888-1.645-7.2219.0788C.9359 2.1526.3086 3.8733.4302 6.3043c.0409.818.5069 3.334 1.2423 5.7436.4598 1.5065.9387 2.7019 1.4334 3.582.553.9942 1.1259 1.5933 1.7143 1.7895.4474.1491 1.1327.1441 1.8581-.7279.8012-.9635 1.5903-1.8258 1.9446-2.2069.4351.2355.9064.3625 1.39.3772a.0569.0569 0 0 0 .0004.0041c-.084.0993-.1664.2007-.2472.3054-.3389.4302-.4094.5197-1.5002.7443-.3102.064-1.1344.2339-1.1464.8115-.0025.1224.0329.2309.0919.3268.2269.4231.9216.6097 1.015.6331 1.3345.3335 2.5044.092 3.3714-.6787-.017 2.231.0775 4.4174.3454 5.0874.2212.5529.7618 1.9045 2.4692 1.9043.2505 0 .5263-.0291.8296-.0941 1.7819-.3821 2.5557-1.1696 2.855-2.9059.1503-.8707.4016-2.8753.5388-4.1012.0169-.0703.0357-.1207.057-.1362.0007-.0005.0697-.0471.4272.0307a.3673.3673 0 0 0 .0443.0068l.2539.0223.0149.001c.8468.0384 1.9114-.1426 2.5312-.4308.6438-.2988 1.8057-1.0323 1.5951-1.6698z" />
                                                </svg>
                                            )}
                                            {n.dbSystem === "redis" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#FF4438" class="shrink-0" aria-hidden="true">
                                                    <path d="M22.71 13.145c-1.66 2.092-3.452 4.483-7.038 4.483-3.203 0-4.397-2.825-4.48-5.12.701 1.484 2.073 2.685 4.214 2.63 4.117-.133 6.94-3.852 6.94-7.239 0-4.05-3.022-6.972-8.268-6.972-3.752 0-8.4 1.428-11.455 3.685C2.59 6.937 3.885 9.958 4.35 9.626c2.648-1.904 4.748-3.13 6.784-3.744C8.12 9.244.886 17.05 0 18.425c.1 1.261 1.66 4.648 2.424 4.648.232 0 .431-.133.664-.365a100.49 100.49 0 0 0 5.54-6.765c.222 3.104 1.748 6.898 6.014 6.898 3.819 0 7.604-2.756 9.33-8.965.2-.764-.73-1.361-1.261-.73zm-4.349-5.013c0 1.959-1.926 2.922-3.685 2.922-.941 0-1.664-.247-2.235-.568 1.051-1.592 2.092-3.225 3.21-4.973 1.972.334 2.71 1.43 2.71 2.619z" />
                                                </svg>
                                            )}
                                            <span class="text-xs font-medium text-fg truncate">{n.label}</span>
                                            {n.dbSystem && (
                                                <span class={`ml-auto shrink-0 text-[8px] font-semibold tracking-wide uppercase ${n.dbSystem === "redis" ? "text-severity-error" : "text-severity-debug"}`}>{n.dbSystem}</span>
                                            )}
                                        </div>

                                        {/* Metrics row */}
                                        <div class="flex gap-4">
                                            <div class="flex flex-col gap-px">
                                                <span class="text-[9px] font-medium tracking-wide text-fg-muted/60 uppercase">{n.db ? "calls/s" : "req/s"}</span>
                                                <span class="text-[11px] font-medium text-fg font-mono tabular-nums">{n.rps}</span>
                                            </div>
                                            {n.err !== undefined && (
                                                <div class="flex flex-col gap-px">
                                                    <span class="text-[9px] font-medium tracking-wide text-fg-muted/60 uppercase">err%</span>
                                                    <span class={`text-[11px] font-medium font-mono tabular-nums ${errCls}`}>{n.err}%</span>
                                                </div>
                                            )}
                                            <div class="flex flex-col gap-px">
                                                <span class="text-[9px] font-medium tracking-wide text-fg-muted/60 uppercase">avg</span>
                                                <span class={`text-[11px] font-medium font-mono tabular-nums ${parseFloat(n.avg) > 100 ? "text-severity-warn" : "text-fg"}`}>{n.avg}</span>
                                            </div>
                                            {!n.db && (
                                                <div class="flex flex-col gap-px ml-auto items-end">
                                                    <span class="text-[9px] font-medium tracking-wide text-fg-muted/60 uppercase">pods</span>
                                                    {n.pods !== undefined ? (
                                                        <span class="flex items-center gap-1 text-[11px] font-medium text-fg font-mono tabular-nums">
                                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fg-muted/70 shrink-0" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
