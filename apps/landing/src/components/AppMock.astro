                                            <div class={`h-1.5 w-1.5 rounded-full shrink-0 ${healthDotCls}`}></div>
                                            {/* Platform / DB icon — inline SVG, brand colors */}
                                            {n.platform === "kubernetes" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#326CE5" class="shrink-0" aria-hidden="true">
