---
import EffectLogo from "../icons/EffectLogo.astro";
import NodeJsLogo from "../icons/NodeJsLogo.astro";
import NextjsLogo from "../icons/NextjsLogo.astro";
import PythonLogo from "../icons/PythonLogo.astro";
import GoLogo from "../icons/GoLogo.astro";
import RustLogo from "../icons/RustLogo.astro";
import OpenJdkLogo from "../icons/OpenJdkLogo.astro";
import CsharpLogo from "../icons/CsharpLogo.astro";
import KotlinLogo from "../icons/KotlinLogo.astro";
import LaravelLogo from "../icons/LaravelLogo.astro";
import DocsCategoryIcon from "./DocsCategoryIcon.astro";

interface Sdk {
    id: string;
    name: string;
    Icon: any;
    href: string;
    available: boolean;
    note?: string;
}

const sdks: Sdk[] = [
    { id: "effect", name: "Effect",  Icon: EffectLogo,  href: "/docs/sdks/effect",                       available: true },
    { id: "node",   name: "Node.js", Icon: NodeJsLogo,  href: "/docs/guides/instrumentation-nodejs",     available: true },
    { id: "nextjs", name: "Next.js", Icon: NextjsLogo,  href: "/docs/guides/instrumentation-nextjs",     available: true },
    { id: "python", name: "Python",  Icon: PythonLogo,  href: "/docs/guides/instrumentation-python",     available: true },
    { id: "go",     name: "Go",      Icon: GoLogo,      href: "/docs/guides/instrumentation-go",         available: true },
    { id: "rust",   name: "Rust",    Icon: RustLogo,    href: "/docs/guides/instrumentation-rust",       available: true },
    { id: "java",   name: "Java",    Icon: OpenJdkLogo, href: "/docs/guides/instrumentation-java",       available: true },
    { id: "csharp", name: "C#",      Icon: CsharpLogo,  href: "/docs/guides/instrumentation-csharp",     available: true },
    { id: "kotlin", name: "Kotlin",  Icon: KotlinLogo,  href: "/docs/guides/instrumentation-kotlin",     available: true },
    { id: "laravel", name: "Laravel", Icon: LaravelLogo, href: "/docs/guides/instrumentation-laravel",    available: true },
];

interface Props {
    activeSdk?: string;
}

const { activeSdk } = Astro.props;
const current = activeSdk ? sdks.find((s) => s.id === activeSdk) : undefined;
const CurrentIcon = current?.Icon;
const isEmpty = !current;
---

<div class="mb-5">
    <div class="text-[10px] text-fg-muted uppercase tracking-wider font-medium mb-2 px-2">
        Select your language
    </div>
    <details class="group relative sdk-selector">
        <summary
            class:list={[
                "flex items-center justify-between gap-2 px-2.5 py-2 border cursor-pointer transition-colors list-none [&::-webkit-details-marker]:hidden",
                isEmpty
                    ? "border-border bg-accent/[0.04] hover:border-accent/50"
                    : "border-border bg-bg hover:border-fg-muted/50",
            ]}
        >
            <span class="flex items-center gap-2.5 min-w-0">
                <span class="w-5 h-5 shrink-0 flex items-center justify-center">
                    {CurrentIcon ? (
                        <CurrentIcon class="w-4 h-4" />
                    ) : (
                        <DocsCategoryIcon name="sdks" class="w-4 h-4 text-accent/80" />
                    )}
                </span>
                <span class="text-xs font-medium truncate text-fg">
                    {current?.name ?? "Choose a language"}
                </span>
            </span>
            <svg class="w-3 h-3 text-fg-muted transition-transform group-open:rotate-180 shrink-0" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l3 3 3-3" />
            </svg>
        </summary>
        <div class="absolute z-30 left-0 right-0 mt-1 border border-border bg-bg shadow-lg max-h-80 overflow-y-auto">
            <ul class="py-1">
                {sdks.map((sdk) => {
                    const Icon = sdk.Icon;
                    const isCurrent = current?.id === sdk.id;
                    return (
                        <li>
                            {sdk.available ? (
                                <a
                                    href={sdk.href}
                                    class:list={[
                                        "w-full flex items-center justify-between gap-2 px-2.5 py-1.5 text-left transition-colors",
                                        isCurrent
                                            ? "bg-accent/5 text-accent"
                                            : "text-fg hover:bg-fg/5",
                                    ]}
                                >
                                    <span class="flex items-center gap-2.5 min-w-0">
                                        <span class="w-5 h-5 shrink-0 flex items-center justify-center">
                                            <Icon class="w-4 h-4" />
                                        </span>
                                        <span class="text-xs font-medium truncate">{sdk.name}</span>
                                    </span>
                                    {isCurrent && (
                                        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M2.5 6l2.5 2.5 4.5-5" />
                                        </svg>
                                    )}
                                </a>
                            ) : (
                                <div class="flex items-center justify-between gap-2 px-2.5 py-1.5 text-fg-muted/60 cursor-not-allowed">
                                    <span class="flex items-center gap-2.5 min-w-0">
                                        <span class="w-5 h-5 shrink-0 flex items-center justify-center opacity-40 grayscale">
                                            <Icon class="w-4 h-4" />
                                        </span>
                                        <span class="text-xs truncate">{sdk.name}</span>
                                    </span>
                                    <span class="text-[9px] uppercase tracking-wider shrink-0">
                                        {sdk.note}
                                    </span>
                                </div>
                            )}
                        </li>
                    );
                })}
            </ul>
        </div>
    </details>
</div>

<script is:inline>
    // Close the open language dropdown when clicking outside it. (Picking a
    // language navigates, which closes it on the new page load.)
    document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        document.querySelectorAll("details.sdk-selector[open]").forEach((d) => {
            if (!d.contains(target)) d.removeAttribute("open");
        });
    });
</script>
