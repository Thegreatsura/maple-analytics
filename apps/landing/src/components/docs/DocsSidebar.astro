---
import { getCollection } from "astro:content";
import SdkSelector from "./SdkSelector.astro";
import DocsCategoryIcon from "./DocsCategoryIcon.astro";
import { SDK_GROUP_ORDER, UNIVERSAL_GROUP_ORDER, SDK_HIDDEN_UNIVERSAL_GROUPS, hasCategoryIcon } from "../../lib/docs-nav";

interface Props {
    currentSlug: string;
}

const { currentSlug } = Astro.props;

const allDocs = await getCollection("docs", ({ data }) => !data.draft);

const currentDoc = allDocs.find((d) => d.id === currentSlug);
const activeSdk: string | null = currentDoc?.data.sdk ?? null;

const sdkScopedDocs = activeSdk ? allDocs.filter((d) => d.data.sdk === activeSdk) : [];
const universalDocs = allDocs.filter(
    (d) => !d.data.sdk && !(activeSdk && SDK_HIDDEN_UNIVERSAL_GROUPS.has(d.data.group)),
);

const groupBy = (docs: typeof allDocs) => {
    const groups = new Map<string, typeof allDocs>();
    for (const doc of docs) {
        const group = doc.data.group;
        if (!groups.has(group)) groups.set(group, []);
        groups.get(group)!.push(doc);
    }
    for (const [, items] of groups) {
        items.sort((a, b) => a.data.order - b.data.order);
    }
    return groups;
};

const orderGroups = (groups: Map<string, typeof allDocs>, groupOrder: string[]) =>
    [...groups.entries()].sort((a, b) => {
        const ai = groupOrder.indexOf(a[0]);
        const bi = groupOrder.indexOf(b[0]);
        return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
    });

const sdkGroups = orderGroups(groupBy(sdkScopedDocs), [...SDK_GROUP_ORDER]);
const universalGroups = orderGroups(groupBy(universalDocs), [...UNIVERSAL_GROUP_ORDER]);
---

<nav aria-label="Documentation sidebar">
    <SdkSelector activeSdk={activeSdk ?? undefined} />

    {sdkGroups.length > 0 && (
        <div class="mb-1">
            {sdkGroups.map(([groupName, items]) => (
                <div class="mb-5">
                    <h3 class="flex items-center gap-1.5 text-[10px] text-fg/75 uppercase tracking-wider font-semibold mb-2 px-2">
                        {hasCategoryIcon(groupName) && (
                            <DocsCategoryIcon name={groupName} class="w-3 h-3 shrink-0 text-primary/80" />
                        )}
                        {groupName}
                    </h3>
                    <ul class="space-y-px">
                        {items.map((doc) => {
                            const isActive = doc.id === currentSlug;
                            return (
                                <li>
                                    <a
                                        href={`/docs/${doc.id}`}
                                        class:list={[
                                            "block py-1.5 px-2 text-xs transition-colors",
                                            isActive
                                                ? "text-primary bg-primary/5 border-l-2 border-primary"
                                                : "text-fg-muted hover:text-fg",
                                        ]}
                                    >
                                        {doc.data.title}
                                    </a>
                                </li>
                            );
                        })}
                    </ul>
                </div>
            ))}
        </div>
    )}

    {sdkGroups.length > 0 && universalGroups.length > 0 && (
        <div class="mt-12 mb-4 px-2 pt-6 border-t border-border/60">
            <p class="text-[10px] uppercase tracking-wider font-semibold text-fg-muted/80">
                General
            </p>
            <p class="text-[10px] text-fg-muted/55 leading-snug mt-0.5">
                Not language-specific — applies to all SDKs
            </p>
        </div>
    )}

    {universalGroups.map(([groupName, items]) => (
        <div class="mb-5">
            <h3 class="flex items-center gap-1.5 text-[10px] text-fg/75 uppercase tracking-wider font-semibold mb-2 px-2">
                {hasCategoryIcon(groupName) && (
                    <DocsCategoryIcon name={groupName} class="w-3 h-3 shrink-0 text-primary/80" />
                )}
                {groupName}
            </h3>
            <ul class="space-y-px">
                {items.map((doc) => {
                    const isActive = doc.id === currentSlug;
                    return (
                        <li>
                            <a
                                href={`/docs/${doc.id}`}
                                class:list={[
                                    "block py-1.5 px-2 text-xs transition-colors",
                                    isActive
                                        ? "text-primary bg-primary/5 border-l-2 border-primary"
                                        : "text-fg-muted hover:text-fg",
                                ]}
                            >
                                {doc.data.title}
                            </a>
                        </li>
                    );
                })}
            </ul>
        </div>
    ))}
</nav>
