---
import { getCollection } from "astro:content";

interface Props {
    currentSlug: string;
}

const { currentSlug } = Astro.props;

const allDocs = await getCollection("docs", ({ data }) => !data.draft);

const groups = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
    const group = doc.data.group;
    if (!groups.has(group)) groups.set(group, []);
    groups.get(group)!.push(doc);
}

for (const [, items] of groups) {
    items.sort((a, b) => a.data.order - b.data.order);
}

const groupOrder = ["Getting Started", "Guides", "Concepts"];
const sortedGroups = [...groups.entries()].sort((a, b) => {
    const ai = groupOrder.indexOf(a[0]);
    const bi = groupOrder.indexOf(b[0]);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
});
---

<nav aria-label="Documentation sidebar">
    {sortedGroups.map(([groupName, items]) => (
        <div class="mb-5">
            <h3 class="text-[10px] text-fg-muted uppercase tracking-wider font-medium mb-2 px-2">
                {groupName}
            </h3>
            <ul class="space-y-px">
                {items.map((doc) => {
                    const isActive = doc.id === currentSlug;
                    return (
                        <li>
                            <a
                                href={`/docs/${doc.id}`}
                                class:list={[
                                    "block py-1.5 px-2 text-xs transition-colors",
                                    isActive
                                        ? "text-accent bg-accent/5 border-l-2 border-accent"
                                        : "text-fg-muted hover:text-fg",
                                ]}
                            >
                                {doc.data.title}
                            </a>
                        </li>
                    );
                })}
            </ul>
        </div>
    ))}
</nav>
