---
import EffectLogo from "../icons/EffectLogo.astro";
import NodeJsLogo from "../icons/NodeJsLogo.astro";
import NextjsLogo from "../icons/NextjsLogo.astro";
import PythonLogo from "../icons/PythonLogo.astro";
import GoLogo from "../icons/GoLogo.astro";
import RustLogo from "../icons/RustLogo.astro";
import OpenJdkLogo from "../icons/OpenJdkLogo.astro";
import CsharpLogo from "../icons/CsharpLogo.astro";
import KotlinLogo from "../icons/KotlinLogo.astro";
import LaravelLogo from "../icons/LaravelLogo.astro";

interface Sdk {
    id: string;
    name: string;
    Icon: any;
    href?: string;
    available: boolean;
}

const sdks: Sdk[] = [
    { id: "effect", name: "Effect",  Icon: EffectLogo,  href: "/docs/sdks/effect",                       available: true },
    { id: "node",   name: "Node.js", Icon: NodeJsLogo,  href: "/docs/guides/instrumentation-nodejs",     available: true },
    { id: "nextjs", name: "Next.js", Icon: NextjsLogo,  href: "/docs/guides/instrumentation-nextjs",     available: true },
    { id: "python", name: "Python",  Icon: PythonLogo,  href: "/docs/guides/instrumentation-python",     available: true },
    { id: "go",     name: "Go",      Icon: GoLogo,      href: "/docs/guides/instrumentation-go",         available: true },
    { id: "rust",   name: "Rust",    Icon: RustLogo,    href: "/docs/guides/instrumentation-rust",       available: true },
    { id: "java",   name: "Java",    Icon: OpenJdkLogo, href: "/docs/guides/instrumentation-java",       available: true },
    { id: "csharp", name: "C#",      Icon: CsharpLogo,  href: "/docs/guides/instrumentation-csharp",     available: true },
    { id: "kotlin", name: "Kotlin",  Icon: KotlinLogo,  href: "/docs/guides/instrumentation-kotlin",     available: true },
    { id: "laravel", name: "Laravel", Icon: LaravelLogo, href: "/docs/guides/instrumentation-laravel",    available: true },
];
---

<div class="mt-10 pt-5 border-t border-border">
    <h4 class="text-[10px] text-fg-muted uppercase tracking-wider font-medium mb-3">
        Available in other languages
    </h4>
    <div class="grid grid-cols-4 gap-1.5">
        {sdks.map((sdk) => {
            const Icon = sdk.Icon;
            return sdk.available && sdk.href ? (
                <a
                    href={sdk.href}
                    title={sdk.name}
                    aria-label={sdk.name}
                    class="aspect-square flex items-center justify-center border border-border bg-bg hover:border-accent/60 hover:bg-accent/5 transition-colors"
                >
                    <Icon class="w-4 h-4" />
                </a>
            ) : (
                <div
                    title={`${sdk.name} (coming soon)`}
                    aria-label={`${sdk.name} (coming soon)`}
                    class="aspect-square flex items-center justify-center border border-border/60 bg-bg cursor-not-allowed opacity-40 grayscale"
                >
                    <Icon class="w-4 h-4" />
                </div>
            );
        })}
    </div>
    <p class="text-[10px] text-fg-muted/70 mt-3 leading-relaxed">
        Need a language we don't cover? <a href="https://github.com/Makisuo/maple/issues" target="_blank" rel="noopener" class="text-fg-muted hover:text-accent underline underline-offset-2 transition-colors">Open an issue</a>.
    </p>
</div>
