---
import { getCollection } from "astro:content";
import DocsCategoryIcon from "./DocsCategoryIcon.astro";
import { HEADER_NAV, SDK_OVERVIEW_SLUG } from "../../lib/docs-nav";

interface Props {
	currentSlug: string;
}
const { currentSlug } = Astro.props;

const allDocs = await getCollection("docs", ({ data }) => !data.draft);
const currentDoc = allDocs.find((d) => d.id === currentSlug);
const activeGroup = currentDoc?.data.group ?? null;
const activeIsSdk = Boolean(currentDoc?.data.sdk);

// First page (lowest `order`) within a universal group → the category's target.
const firstHrefForGroup = (group: string): string | null => {
	const page = allDocs
		.filter((d) => !d.data.sdk && d.data.group === group)
		.sort((a, b) => a.data.order - b.data.order)[0];
	return page ? `/docs/${page.id}` : null;
};

type Cat = { label: string; icon: string; href: string; active: boolean };
const cats: Cat[] = [];
for (const item of HEADER_NAV) {
	if (item.kind === "sdks") {
		cats.push({ label: item.key, icon: item.icon, href: `/docs/${SDK_OVERVIEW_SLUG}`, active: activeIsSdk });
		continue;
	}
	const href = firstHrefForGroup(item.key);
	if (!href) continue; // group has no published pages — skip
	cats.push({ label: item.key, icon: item.icon, href, active: !activeIsSdk && activeGroup === item.key });
}
---

<nav class="docs-cat-nav flex items-stretch gap-0.5 h-11 px-3 sm:px-5 border-t border-border/60 overflow-x-auto" aria-label="Documentation categories">
	{cats.map((cat) => (
		<a
			href={cat.href}
			aria-current={cat.active ? "page" : undefined}
			class:list={[
				"group relative flex items-center gap-2 px-2.5 text-[11px] font-medium whitespace-nowrap transition-colors",
				cat.active ? "text-accent" : "text-fg-muted hover:text-fg",
			]}
		>
			<DocsCategoryIcon
				name={cat.icon}
				class:list={[
					"w-3.5 h-3.5 shrink-0 transition-colors",
					cat.active ? "text-accent" : "text-fg-muted/70 group-hover:text-fg-muted",
				]}
			/>
			<span class="tracking-wide">{cat.label}</span>
			<span
				class:list={[
					"pointer-events-none absolute inset-x-1 -bottom-px h-0.5 bg-accent transition-opacity",
					cat.active ? "opacity-100" : "opacity-0 group-hover:opacity-30",
				]}
			></span>
		</a>
	))}
</nav>

<style>
	/* Hide the horizontal scrollbar on the category strip (it scrolls on narrow viewports). */
	.docs-cat-nav {
		scrollbar-width: none;
	}
	.docs-cat-nav::-webkit-scrollbar {
		display: none;
	}
</style>
