---
interface Props {
    stats: Array<{ value: string; label: string; detail: string }>;
}

const { stats } = Astro.props;
---

<section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border">
            {stats.map(stat => (
                <div class="bg-bg p-6 md:p-8 text-center">
                    <div class="text-3xl md:text-4xl font-bold text-accent mb-2">{stat.value}</div>
                    <div class="text-sm font-semibold text-fg mb-1">{stat.label}</div>
                    <p class="text-xs text-fg-muted leading-relaxed">{stat.detail}</p>
                </div>
            ))}
        </div>
    </div>
</section>
