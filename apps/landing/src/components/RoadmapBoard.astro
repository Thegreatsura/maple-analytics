---
import { getCollection } from "astro:content"

const allItems = await getCollection("roadmap")
const sorted = [...allItems].sort((a, b) => a.data.order - b.data.order)
const total = sorted.length

type StatusKey = "shipped" | "in-progress" | "planned" | "exploring"

const STATUS: Record<StatusKey, { label: string; dot: string; text: string; bar: string }> = {
	shipped: { label: "Shipped", dot: "bg-chart-2", text: "text-chart-2", bar: "bg-chart-2" },
	"in-progress": { label: "In progress", dot: "bg-chart-3", text: "text-chart-3", bar: "bg-chart-3" },
	planned: { label: "Planned", dot: "bg-primary", text: "text-primary", bar: "bg-primary" },
	exploring: { label: "Exploring", dot: "bg-chart-4", text: "text-chart-4", bar: "bg-chart-4" },
}

const categoryStyles: Record<string, string> = {
	traces: "border-chart-1/30 bg-chart-1/10 text-chart-1",
	logs: "border-chart-2/30 bg-chart-2/10 text-chart-2",
	metrics: "border-chart-3/30 bg-chart-3/10 text-chart-3",
	alerting: "border-chart-5/30 bg-chart-5/10 text-chart-5",
	integrations: "border-primary/30 bg-primary/10 text-primary",
	platform: "border-chart-4/30 bg-chart-4/10 text-chart-4",
	ai: "border-chart-p50/30 bg-chart-p50/10 text-chart-p50",
}

const meterOrder: StatusKey[] = ["shipped", "in-progress", "planned", "exploring"]
const counts = Object.fromEntries(
	meterOrder.map((k) => [k, sorted.filter((i) => i.data.status === k).length]),
) as Record<StatusKey, number>
const shippedCount = counts.shipped

// "Now / Next / Later" lanes — lead with momentum, not the shipped wall.
const lanes: { key: StatusKey; kicker: string; blurb: string }[] = [
	{ key: "in-progress", kicker: "Now", blurb: "Being built right now." },
	{ key: "planned", kicker: "Next", blurb: "Committed and queued up." },
	{ key: "exploring", kicker: "Later", blurb: "On the radar — scoping." },
]

// Shipped ledger, newest shipments first.
const shippedItems = sorted
	.filter((i) => i.data.status === "shipped")
	.sort(
		(a, b) =>
			(b.data.shipped_date ?? "").localeCompare(a.data.shipped_date ?? "") ||
			a.data.order - b.data.order,
	)
---

<section class="py-16 md:py-24">
	<div class="mx-auto max-w-6xl px-6">

		<!-- ── Shipment meter ───────────────────────────────────────── -->
		<div class="border border-border bg-bg-elevated mb-16 md:mb-20">
			<div class="flex items-center justify-between gap-3 px-4 md:px-5 py-2.5 border-b border-border">
				<div class="flex items-center gap-2">
					<div class="w-1.5 h-1.5 rounded-full bg-chart-3 animate-pulse-dot"></div>
					<span class="font-mono text-[11px] uppercase tracking-[0.15em] text-fg-muted">build.progress</span>
				</div>
				<span class="font-mono text-[11px] tracking-wider text-fg-muted">
					<span class="text-chart-2 font-medium">{shippedCount}</span> / {total} shipped
				</span>
			</div>

			<div class="px-4 md:px-5 pt-5 pb-4">
				<!-- Segmented progress bar -->
				<div class="flex h-3 w-full gap-px border border-border bg-border overflow-hidden">
					{meterOrder.map((k, idx) => {
						const c = counts[k]
						if (!c) return null
						const pct = (c / total) * 100
						return (
							<div
								class={`roadmap-seg h-full ${STATUS[k].bar}`}
								style={`width:${pct}%;animation-delay:${idx * 120}ms`}
								title={`${STATUS[k].label}: ${c}`}
							/>
						)
					})}
				</div>

				<!-- Stat readouts -->
				<div class="mt-5 grid grid-cols-2 md:grid-cols-4 gap-px bg-border border border-border">
					{meterOrder.map((k) => (
						<div class="bg-bg-elevated px-4 py-3.5">
							<div class="flex items-center gap-2 mb-2">
								<div class={`w-2 h-2 rounded-full ${STATUS[k].dot} ${k === "in-progress" ? "animate-pulse-dot" : ""}`} />
								<span class="font-mono text-[10px] uppercase tracking-[0.12em] text-fg-muted">{STATUS[k].label}</span>
							</div>
							<div class={`font-display text-3xl md:text-4xl font-semibold tabular-nums leading-none ${STATUS[k].text}`}>
								{String(counts[k]).padStart(2, "0")}
							</div>
						</div>
					))}
				</div>
			</div>
		</div>

		<!-- ── Now / Next / Later ───────────────────────────────────── -->
		<div class="mb-6 flex items-baseline gap-4">
			<h2 class="font-display text-xl md:text-2xl font-semibold tracking-tight text-fg">In flight</h2>
			<div class="flex-1 border-t border-border"></div>
			<span class="font-mono text-[10px] uppercase tracking-[0.12em] text-fg-muted">now · next · later</span>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border mb-16 md:mb-20">
			{lanes.map((lane, laneIdx) => {
				const items = sorted.filter((i) => i.data.status === lane.key)
				const s = STATUS[lane.key]
				const isNow = lane.key === "in-progress"
				return (
					<div class="relative bg-bg p-5 md:p-6">
						{isNow && <div class="absolute inset-x-0 top-0 h-px bg-chart-3" />}

						<div class="flex items-center gap-2.5">
							<div class={`w-2 h-2 rounded-full ${s.dot} ${isNow ? "animate-pulse-dot" : ""}`} />
							<span class={`font-mono text-[11px] uppercase tracking-[0.15em] font-medium ${s.text}`}>{lane.kicker}</span>
							<span class="font-mono text-[10px] text-fg-muted">[{items.length}]</span>
						</div>
						<p class="mt-1.5 mb-5 text-[12px] text-fg-muted">{lane.blurb}</p>

						<div class="space-y-3">
							{items.map((item, i) => (
								<article
									class="roadmap-reveal border border-border bg-bg-elevated p-4 transition-colors duration-200 hover:border-fg-muted/40"
									style={`animation-delay:${laneIdx * 90 + i * 70}ms`}
								>
									<div class="flex items-center justify-between gap-2 mb-2.5">
										<span class={`font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 border ${categoryStyles[item.data.category] ?? "border-border text-fg-muted"}`}>
											{item.data.category}
										</span>
										<span class="font-mono text-[10px] text-fg-muted">{item.data.quarter}</span>
									</div>
									<h3 class="text-sm font-semibold text-fg leading-snug mb-1.5">{item.data.title}</h3>
									<p class="text-[13px] text-fg-muted leading-relaxed">{item.data.description}</p>
								</article>
							))}
							{items.length === 0 && (
								<div class="border border-dashed border-border p-4 text-[12px] text-fg-muted/60">Nothing here yet.</div>
							)}
						</div>
					</div>
				)
			})}
		</div>

		<!-- ── Shipped ledger ───────────────────────────────────────── -->
		<div class="mb-6 flex items-baseline gap-4">
			<h2 class="font-display text-xl md:text-2xl font-semibold tracking-tight text-fg">Shipped</h2>
			<div class="flex-1 border-t border-border"></div>
			<span class="font-mono text-[10px] uppercase tracking-[0.12em] text-chart-2">{shippedItems.length} features</span>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border border border-border">
			{shippedItems.map((item, i) => (
				<div
					class="roadmap-reveal flex items-center gap-3.5 bg-bg px-4 md:px-5 py-3.5 transition-colors duration-200 hover:bg-bg-elevated"
					style={`animation-delay:${i * 45}ms`}
				>
					<svg viewBox="0 0 16 16" fill="none" class="shrink-0 w-3.5 h-3.5 text-chart-2" aria-hidden="true">
						<path d="M3.5 8.5l2.8 2.8L12.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
					<h3 class="min-w-0 flex-1 truncate text-[13px] font-medium text-fg">{item.data.title}</h3>
					<span class={`hidden sm:inline-block shrink-0 font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 border ${categoryStyles[item.data.category] ?? "border-border text-fg-muted"}`}>
						{item.data.category}
					</span>
					<span class="shrink-0 font-mono text-[11px] text-fg-muted tabular-nums">{item.data.shipped_date}</span>
				</div>
			))}
		</div>

	</div>
</section>
