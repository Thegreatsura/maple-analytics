---
import "../styles/global.css";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsTableOfContents from "../components/docs/DocsTableOfContents.astro";
import DocsPrevNext from "../components/docs/DocsPrevNext.astro";
import DocsMobileNav from "../components/docs/DocsMobileNav.astro";
import DocsCategoryNav from "../components/docs/DocsCategoryNav.astro";
import AvailableSdks from "../components/docs/AvailableSdks.astro";
import DocsSearch from "../components/docs/DocsSearch.tsx";
import { getGitHubStars } from "../lib/github-stars";
import { GithubStarButton } from "../components/GithubStarButton";

interface Props {
    title: string;
    description: string;
    headings: Array<{ depth: number; slug: string; text: string }>;
    currentSlug: string;
}

const { title, description, headings, currentSlug } = Astro.props;
const stars = await getGitHubStars();

const pageTitle = currentSlug ? `${title} — Maple Docs` : "Maple Docs";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#272219" />
        <meta name="robots" content="index,follow" />
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:type" content="article" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
    </head>
    <body class="min-h-screen antialiased bg-bg text-fg font-sans">
        <!-- Docs header -->
        <header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/95 backdrop-blur-md">
            <div class="h-12 flex items-center justify-between px-5">
                <div class="flex items-center gap-3">
                    <a href="/" class="flex items-center gap-2.5 text-fg-muted hover:text-fg transition-colors">
                        <div class="w-5 h-5 bg-primary flex items-center justify-center">
                            <span class="text-primary-foreground text-[9px] font-bold">M</span>
                        </div>
                        <span class="text-xs font-medium text-fg">Maple</span>
                    </a>
                    <a
                        href="/docs"
                        class="text-[10px] uppercase tracking-wider font-medium px-1.5 py-0.5 border border-border text-fg-muted hover:text-fg hover:border-fg-muted/50 transition-colors"
                    >
                        Docs
                    </a>
                </div>
                <div class="flex items-center gap-4">
                    <DocsSearch client:idle />
                    <GithubStarButton stars={stars} className="inline-flex" />
                    <a
                        href="https://app.maple.dev"
                        class="text-[10px] text-fg-muted hover:text-primary transition-colors font-medium uppercase tracking-wider"
                    >
                        App
                    </a>
                </div>
            </div>
            <DocsCategoryNav currentSlug={currentSlug} />
        </header>

        <div class="pt-[5.75rem] min-h-screen flex">
            <!-- Sidebar -->
            <aside class="hidden lg:block w-60 shrink-0 fixed top-[5.75rem] left-0 bottom-0 overflow-y-auto border-r border-border py-6 px-5">
                <DocsSidebar currentSlug={currentSlug} />
            </aside>

            <!-- Main content -->
            <main class="flex-1 min-w-0 lg:ml-60 xl:mr-52">
                <div class="max-w-3xl mx-auto py-10 px-6">
                    <DocsMobileNav currentSlug={currentSlug} />
                    <slot />
                    {currentSlug && <DocsPrevNext currentSlug={currentSlug} />}
                </div>
            </main>

            <!-- Table of Contents -->
            <aside class="hidden xl:block w-52 shrink-0 fixed top-[5.75rem] right-0 bottom-0 overflow-y-auto py-6 px-5 border-l border-border">
                <DocsTableOfContents headings={headings} />
                <AvailableSdks />
            </aside>
        </div>
    </body>
</html>
