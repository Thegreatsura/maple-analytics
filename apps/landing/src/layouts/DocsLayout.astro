---
import "../styles/global.css";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsTableOfContents from "../components/docs/DocsTableOfContents.astro";
import DocsPrevNext from "../components/docs/DocsPrevNext.astro";
import DocsMobileNav from "../components/docs/DocsMobileNav.astro";

interface Props {
    title: string;
    description: string;
    headings: Array<{ depth: number; slug: string; text: string }>;
    currentSlug: string;
}

const { title, description, headings, currentSlug } = Astro.props;

const pageTitle = currentSlug ? `${title} — Maple Docs` : "Maple Docs";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#272219" />
        <meta name="robots" content="index,follow" />
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:type" content="article" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
    </head>
    <body class="min-h-screen antialiased bg-bg text-fg font-sans">
        <!-- Docs header -->
        <header class="fixed top-0 left-0 right-0 z-50 h-12 border-b border-border bg-bg/95 backdrop-blur-md">
            <div class="h-full flex items-center justify-between px-5">
                <div class="flex items-center gap-4">
                    <a href="/" class="flex items-center gap-2.5 text-fg-muted hover:text-fg transition-colors">
                        <div class="w-5 h-5 bg-accent flex items-center justify-center">
                            <span class="text-accent-foreground text-[9px] font-bold">M</span>
                        </div>
                        <span class="text-xs font-medium text-fg">Maple</span>
                    </a>
                    <span class="text-border">/</span>
                    <a href="/docs" class="text-xs text-fg-muted hover:text-fg transition-colors">
                        Docs
                    </a>
                </div>
                <div class="flex items-center gap-4">
                    <a
                        href="https://github.com/Makisuo/maple"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-fg-muted hover:text-fg transition-colors"
                    >
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                    </a>
                    <a
                        href="https://app.maple.dev"
                        class="text-[10px] text-fg-muted hover:text-accent transition-colors font-medium uppercase tracking-wider"
                    >
                        App
                    </a>
                </div>
            </div>
        </header>

        <div class="pt-12 min-h-screen flex">
            <!-- Sidebar -->
            <aside class="hidden lg:block w-60 shrink-0 fixed top-12 left-0 bottom-0 overflow-y-auto border-r border-border py-6 px-5">
                <DocsSidebar currentSlug={currentSlug} />
            </aside>

            <!-- Main content -->
            <main class="flex-1 min-w-0 lg:ml-60 xl:mr-52">
                <div class="max-w-3xl mx-auto py-10 px-6">
                    <DocsMobileNav currentSlug={currentSlug} />
                    <slot />
                    {currentSlug && <DocsPrevNext currentSlug={currentSlug} />}
                </div>
            </main>

            <!-- Table of Contents -->
            <aside class="hidden xl:block w-52 shrink-0 fixed top-12 right-0 bottom-0 overflow-y-auto py-6 px-5 border-l border-border">
                <DocsTableOfContents headings={headings} />
            </aside>
        </div>
    </body>
</html>
