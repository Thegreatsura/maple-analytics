---
import { getRelativeLocaleUrl } from "astro:i18n";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    ogType?: "website" | "article";
}

const {
    title = "Open Source Observability for Traces, Logs & Metrics — Maple",
    description = "Open-source observability platform for traces, logs, and metrics. Built on OpenTelemetry.",
    image = "/og-image.png",
    ogType = "website",
} = Astro.props;

const currentLocale = Astro.currentLocale ?? "en";
const localeMap: Record<string, string> = { en: "en_US", ja: "ja_JP", ko: "ko_KR" };
const ogLocale = localeMap[currentLocale] ?? "en_US";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteImage = image.startsWith("http")
    ? image
    : new URL(image, Astro.site).toString();

// Build path without locale prefix for hreflang generation
const pathWithoutLocale = Astro.url.pathname
    .replace(/^\/(ja|ko)(\/|$)/, "/")
    .replace(/\/+/g, "/");
const locales = ["en", "ja", "ko"];
---

<!doctype html>
<!-- Landing is dark-only: pin the shared theme's dark class (tokens live in
     @maple/ui/styles/tokens.css; light values exist but are unused here). -->
<html lang={currentLocale} class="dark">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="192x192" href="/logo192.png" />
        <link rel="manifest" href="/manifest.json" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#272219" />
        <meta name="robots" content="index,follow" />
        <link rel="canonical" href={canonicalUrl} />
        {locales.map((locale) => (
            <link
                rel="alternate"
                hreflang={locale}
                href={new URL(getRelativeLocaleUrl(locale, pathWithoutLocale), Astro.site).toString()}
            />
        ))}
        <link rel="alternate" hreflang="x-default" href={new URL(pathWithoutLocale, Astro.site).toString()} />
        <link rel="dns-prefetch" href="https://cdn.brandfetch.io" />
        <link rel="preconnect" href="https://cdn.brandfetch.io" crossorigin />
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Maple" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={absoluteImage} />
        <meta property="og:url" content={canonicalUrl} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@maple_dev" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={absoluteImage} />
        <meta name="generator" content={Astro.generator} />
        <script
            is:inline
            src="https://analytics.ahrefs.com/analytics.js"
            data-key="VKnjG071OvfESS7TIl25eA"
            async></script>
        <title>{title}</title>
    </head>
    <body class="min-h-screen antialiased">
        <slot />
        <script is:inline>
            (function() {
                if (/^\/(ja|ko)(\/|$)/.test(window.location.pathname)) return;
                if (sessionStorage.getItem('locale-redirected')) return;
                var supported = ['ja', 'ko'];
                var langs = navigator.languages || [navigator.language];
                for (var i = 0; i < langs.length; i++) {
                    var lang = langs[i].split('-')[0].toLowerCase();
                    if (supported.indexOf(lang) !== -1) {
                        sessionStorage.setItem('locale-redirected', '1');
                        window.location.replace('/' + lang + window.location.pathname);
                        return;
                    }
                }
            })();
        </script>
    </body>
</html>
