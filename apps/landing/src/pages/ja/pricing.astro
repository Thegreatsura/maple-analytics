---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import FeatureHero from "../../components/FeatureHero.astro";
import PricingTable from "../../components/PricingTable.astro";
import FAQ from "../../components/FAQ.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import Footer from "../../components/Footer.astro";
import SeoHead from "../../components/SeoHead.astro";

const pageTitle = "Simple, Transparent Pricing — Maple";
const pageDescription = "Transparent usage-based pricing for logs, traces, and metrics. No per-seat fees, no hidden costs.";

const faqItems = [
    {
        question: "How does data ingestion work?",
        answer: "Maple measures ingestion by the volume of data you send — logs, traces, and metrics are each measured in gigabytes. Each plan includes a monthly data allowance per signal type. Check the plans above for exact limits."
    },
    {
        question: "What happens if I exceed my plan limits?",
        answer: "We'll notify you as you approach your limits. On the Startup plan, additional usage is billed at transparent per-GB rates with no surprises."
    },
    {
        question: "How long is data retained?",
        answer: "Retention varies by plan — the Startup plan includes 30-day retention and Enterprise plans offer custom retention periods. All plans include full query access to your retained data."
    },
    {
        question: "Is Maple compatible with OpenTelemetry?",
        answer: "Yes — Maple is built natively on OpenTelemetry. Any application instrumented with OTel SDKs or the OTel Collector can send data directly to Maple with zero code changes. No proprietary agents required."
    },
    {
        question: "Can I self-host Maple?",
        answer: "Yes. Maple's source is available under FSL-1.1, and the project can be self-hosted on your own infrastructure. The cloud plan is available for teams that prefer a managed experience."
    },
    {
        question: "Do you offer a free trial for paid plans?",
        answer: "Yes, all plans include a free trial so you can explore all features before committing."
    }
];
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} />
    <Nav />
    <FeatureHero
        label="Pricing"
        title="Simple, transparent pricing"
        subtitle="Transparent, usage-based pricing — no per-seat fees, no hidden costs, no vendor lock-in. Trials available on every plan."
    />
    <PricingTable />
    <FAQ items={faqItems} />
    <BottomCTA />
    <Footer />
</Layout>
