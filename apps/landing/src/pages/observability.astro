---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import FeatureHero from "../components/FeatureHero.astro";
import FAQ from "../components/FAQ.astro";
import BottomCTA from "../components/BottomCTA.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const pageTitle = "What Is Observability? Traces, Logs & Metrics Explained";
const pageDescription =
    "Observability is the ability to understand a system's internal state from the telemetry it emits — traces, logs, and metrics. A plain-English guide to the three pillars, observability vs monitoring, and how to choose a platform.";

const lastUpdated = "June 2026";

const pillarFaqs = [
    {
        question: "What is observability in software?",
        answer:
            "Observability is the ability to understand what's happening inside a software system from the outside, by collecting and correlating the telemetry it emits — traces, logs, and metrics. A system is observable when you can answer new questions about its behavior without shipping new code to instrument it.",
    },
    {
        question: "What are the three pillars of observability?",
        answer:
            "Traces, logs, and metrics. A trace records the full path of a single request across your services as timed spans; logs are timestamped records of discrete events; and metrics are numeric measurements sampled over time, like request rate, error rate, and latency. Correlating all three is what lets you move from “something is wrong” to “here's exactly why.”",
    },
    {
        question: "What's the difference between observability and monitoring?",
        answer:
            "Monitoring tells you whether a system is broken; observability helps you understand why. Monitoring watches known failure modes with predefined dashboards and alerts, while observability lets you explore unknown problems by querying rich, high-cardinality telemetry after the fact.",
    },
    {
        question: "How is observability related to OpenTelemetry?",
        answer:
            "OpenTelemetry is the open, vendor-neutral standard for generating and exporting traces, logs, and metrics. Instrumenting with OpenTelemetry means your telemetry isn't tied to one vendor — you can send it to any compatible backend and switch tools without re-instrumenting your code.",
    },
    {
        question: "What should I look for in an observability platform?",
        answer:
            "Native OpenTelemetry support (so you avoid lock-in), unified traces, logs, and metrics in one place, query speed at high cardinality, transparent pricing that doesn't punish you for scaling, and the option to self-host. See our roundup of the best open-source observability tools for a side-by-side.",
    },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} type="WebPage" />
    <Nav />
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "What is observability?" }]} />

    <FeatureHero
        label="Learn"
        title="What is observability?"
        subtitle="Understand a system's internal state from the outside — by collecting and correlating the telemetry it emits."
    />

    <!-- Definition -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">Definition</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">A plain-English definition</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-base md:text-lg text-fg leading-relaxed">
                    Observability is the ability to understand what's happening inside a software system from the
                    outside — by collecting and correlating the telemetry it emits: traces, logs, and metrics.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    The term comes from control theory, where a system is “observable” if you can infer its internal
                    state from its outputs. Applied to software, it means a well-instrumented service produces enough
                    signal that you can answer new questions about its behavior — including ones you didn't anticipate —
                    without stopping to add new instrumentation first.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    That distinction matters most during incidents. Modern systems are distributed, asynchronous, and
                    full of emergent behavior, so the failure you're debugging is often one nobody predicted.
                    Observability is what lets you explore those unknown-unknowns from the data you already collect.
                </p>
            </div>
        </div>
    </section>

    <!-- The three pillars -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">The three pillars</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg mb-12 max-w-2xl">Traces, logs, and metrics</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border">
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">Traces</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">
                        A trace records the full path of a single request as it moves through your services, broken into
                        timed spans. Traces show you where time went and which hop failed.
                    </p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">Logs</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">
                        Logs are timestamped, structured records of discrete events — the detail you read when you need
                        to know exactly what happened at a specific moment.
                    </p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">Metrics</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">
                        Metrics are numeric measurements sampled over time — request rate, error rate, latency,
                        saturation — ideal for dashboards, trends, and alerting.
                    </p>
                </div>
            </div>
            <p class="mt-6 max-w-3xl text-sm md:text-base text-fg-muted leading-relaxed">
                The pillars are most useful together. A metric tells you error rate spiked; a trace shows you the one
                request path responsible; the logs on that span tell you why. Correlation across all three is what turns
                raw telemetry into an answer.
            </p>
        </div>
    </section>

    <!-- Observability vs monitoring -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">Observability vs monitoring</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">How they differ</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-base md:text-lg text-fg leading-relaxed">
                    Monitoring tells you whether a system is broken; observability helps you understand why.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    Monitoring watches known failure modes with predefined dashboards and alerts — it's how you find out
                    a service is down or latency crossed a threshold. It answers questions you knew to ask in advance.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    Observability picks up where monitoring stops. By keeping rich, high-cardinality telemetry you can
                    query after the fact, it lets you investigate problems you never anticipated. Monitoring is a subset
                    of what an observable system makes possible — not a competing idea.
                </p>
            </div>
        </div>
    </section>

    <!-- Observability and OpenTelemetry -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">Standards</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">Observability and OpenTelemetry</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    OpenTelemetry is the open, vendor-neutral standard for generating and exporting traces, logs, and
                    metrics. Instrumenting with OpenTelemetry means your telemetry isn't tied to any one vendor — you can
                    send it to any compatible backend and switch tools without re-instrumenting your code.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    That's why OpenTelemetry has become the default foundation for observability. Read
                    <a href="/opentelemetry" class="text-primary hover:underline">our guide to OpenTelemetry</a> for how
                    the standard works and how Maple follows it.
                </p>
            </div>
        </div>
    </section>

    <!-- How to choose -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">Choosing a platform</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">How to choose an observability platform</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    Look for native OpenTelemetry support so you avoid lock-in, unified traces, logs, and metrics in one
                    place, query speed at high cardinality, transparent pricing that doesn't punish you for scaling, and
                    the option to self-host.
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    For a side-by-side of the leading open-source options, see our roundup of the
                    <a href="/best-open-source-observability-tools" class="text-primary hover:underline">
                        best open-source observability tools
                    </a>.
                </p>
            </div>
            <p class="mt-8 text-[11px] text-fg-muted uppercase tracking-wider">Last updated: {lastUpdated}</p>
        </div>
    </section>

    <FAQ items={pillarFaqs} />
    <BottomCTA />
    <Footer />
</Layout>
