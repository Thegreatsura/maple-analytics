---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import FeatureHero from "../components/FeatureHero.astro";
import FAQ from "../components/FAQ.astro";
import BottomCTA from "../components/BottomCTA.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import {
    bestObservabilityTools,
    listicleFaqs,
    methodology,
    lastUpdated,
} from "../lib/best-observability-tools";

const pageTitle = "Best Open-Source Observability Tools in 2026";
const pageDescription =
    "An honest, ranked roundup of the best open-source observability platforms — OpenTelemetry-native traces, logs, and metrics you can self-host. Compare Maple, Grafana, SigNoz, HyperDX, and more. Updated June 2026.";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://maple.dev";
const pageUrl = `${siteUrl}/best-open-source-observability-tools`;

// Format-native schema only (ItemList for the listicle, FAQPage via FAQ.astro).
// We deliberately don't pile on speculative markup — Ahrefs found schema had
// near-zero impact on AI citations.
const itemListJsonLd = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
    numberOfItems: bestObservabilityTools.length,
    itemListElement: bestObservabilityTools.map((tool) => ({
        "@type": "ListItem",
        position: tool.rank,
        name: tool.name,
        url: tool.url,
    })),
};
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} type="WebPage" />
    <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />

    <Nav />
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Best open-source observability tools" }]} />

    <FeatureHero
        label="Guide"
        title="Best open-source observability tools in 2026"
        subtitle="OpenTelemetry-native traces, logs, and metrics you can self-host — ranked honestly, with what each tool is genuinely best for."
    />

    <!-- Intro + methodology + last updated -->
    <section class="py-12 md:py-16">
        <div class="mx-auto max-w-6xl px-6">
            <p class="max-w-3xl text-sm md:text-base text-fg-muted leading-relaxed">{methodology}</p>
            <p class="mt-6 text-[11px] text-fg-muted uppercase tracking-wider">Last updated: {lastUpdated}</p>
        </div>
    </section>

    <!-- Quick picks summary -->
    <section class="pb-8">
        <div class="mx-auto max-w-6xl px-6">
            <div class="border border-border">
                <div class="border-b border-border px-5 py-3 text-[11px] uppercase tracking-wider text-accent">
                    At a glance
                </div>
                <ul class="divide-y divide-border">
                    {bestObservabilityTools.map((tool) => (
                        <li class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 px-5 py-3">
                            <a
                                href={`#${tool.slug}`}
                                class="shrink-0 sm:w-64 text-sm font-medium text-fg hover:text-accent transition-colors"
                            >
                                {tool.rank}. {tool.name}
                            </a>
                            <span class="text-sm text-fg-muted">{tool.bestFor}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </section>

    <!-- Ranked entries -->
    <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-6xl px-6">
            <div class="grid grid-cols-1 gap-px bg-border border border-border">
                {bestObservabilityTools.map((tool) => (
                    <article id={tool.slug} class="bg-bg p-6 md:p-8 scroll-mt-24">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <div class="flex items-center gap-3">
                                    <span class="inline-flex h-7 w-7 items-center justify-center border border-border text-xs font-bold text-accent">
                                        {tool.rank}
                                    </span>
                                    <h2 class="text-xl md:text-2xl font-bold text-fg">{tool.name}</h2>
                                </div>
                                <p class="mt-2 text-sm text-accent">Best for: {tool.bestFor}</p>
                            </div>
                            <span class="shrink-0 text-[11px] text-fg-muted border border-border px-2 py-1">{tool.license}</span>
                        </div>

                        <p class="mt-4 max-w-3xl text-sm md:text-base text-fg-muted leading-relaxed">{tool.summary}</p>

                        <div class="mt-6 grid gap-6 sm:grid-cols-2">
                            <div>
                                <h3 class="text-[11px] uppercase tracking-wider text-fg-muted mb-2">Strengths</h3>
                                <ul class="space-y-1.5">
                                    {tool.pros.map((p) => (
                                        <li class="flex gap-2 text-sm text-fg-muted">
                                            <span class="text-accent">+</span><span>{p}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                            <div>
                                <h3 class="text-[11px] uppercase tracking-wider text-fg-muted mb-2">Trade-offs</h3>
                                <ul class="space-y-1.5">
                                    {tool.cons.map((c) => (
                                        <li class="flex gap-2 text-sm text-fg-muted">
                                            <span class="text-fg-muted">–</span><span>{c}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>

                        <div class="mt-6 flex flex-wrap items-center gap-4 text-xs">
                            <a
                                href={tool.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-fg hover:text-accent transition-colors"
                            >
                                Visit {tool.name} ↗
                            </a>
                            {tool.comparePath && (
                                <a href={tool.comparePath} class="text-fg-muted hover:text-accent transition-colors">
                                    Maple vs {tool.name.split(" ")[0]}
                                </a>
                            )}
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- How to choose / cross-links -->
    <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-6xl px-6">
            <div class="border border-border p-6 md:p-8 max-w-3xl">
                <h2 class="text-xl md:text-2xl font-bold text-fg">How to choose</h2>
                <p class="mt-3 text-sm md:text-base text-fg-muted leading-relaxed">
                    Start with how your team already works. If you've standardized on OpenTelemetry, an OTel-native
                    platform avoids re-instrumentation later. New to the category? Read
                    <a href="/observability" class="text-accent hover:underline">what observability is</a> and
                    <a href="/opentelemetry" class="text-accent hover:underline">why OpenTelemetry matters</a> first,
                    then come back to this list.
                </p>
            </div>
        </div>
    </section>

    <FAQ items={listicleFaqs} />
    <BottomCTA />
    <Footer />
</Layout>
