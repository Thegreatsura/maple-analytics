---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import SeoHead from "../components/SeoHead.astro";
import LocalProductHero from "../components/local/LocalProductHero.astro";
import LocalLoopback from "../components/local/LocalLoopback.astro";
import LocalCommandGrid from "../components/local/LocalCommandGrid.astro";
import LocalEyebrow from "../components/local/LocalEyebrow.astro";
import LiveTrace from "../components/live/LiveTrace.astro";
import LiveLogStream from "../components/live/LiveLogStream.astro";
import LiveLogsVolumeChart from "../components/live/LiveLogsVolumeChart.tsx";
import LiveServiceMap from "../components/live/LiveServiceMap.astro";
import BottomCTA from "../components/BottomCTA.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Maple Local | Observability on localhost";
const pageDescription =
    "Run Maple as a single binary on your machine — OTLP ingest, an embedded ClickHouse, a query API, and the dashboard, with no cloud and no auth.";

const valueProps = [
    {
        title: "One binary, zero deps",
        body: "A single Bun-compiled `maple` executable bundles OTLP ingest, the query API, and the dashboard. No runtime to install, no second language — it talks to ClickHouse in-process via libchdb.",
    },
    {
        title: "Fully local, no auth",
        body: "Everything runs on 127.0.0.1 — no cloud workspace, no account, no rate limits. Data persists in ~/.maple/data between runs, and `--offline` serves the UI from the binary with no internet at all.",
    },
    {
        title: "Embedded ClickHouse",
        body: "The same column store that powers hosted Maple, running in-process as chDB. Traces, logs, and metrics are queryable in sub-second time the moment they land.",
    },
    {
        title: "OTLP-native",
        body: "Speaks OTLP/HTTP on POST /v1/{traces,logs,metrics} — the protocol every OpenTelemetry SDK already exports. Point your app at :4318; no exporter changes, no auth header.",
    },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} type="SoftwareApplication" />

    <Nav />
    <LocalProductHero />

    <!-- 01 — Why local. Value-prop grid. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-12">
                <LocalEyebrow index="01" label="Why local" />
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    The fastest way to look at OpenTelemetry data
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                    Point any OTLP exporter at localhost, open the dashboard, and explore traces, logs, and
                    metrics — no account, nothing to deploy. Everything is single-tenant: every row is stored
                    under <code class="text-primary font-mono text-[0.9em]">org_id = "local"</code>.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
                {
                    valueProps.map((p, i) => (
                        <div class="vp">
                            <span class="vp__idx" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                            <h3 class="font-display text-base md:text-lg font-semibold text-fg tracking-tight">
                                {p.title}
                            </h3>
                            <p class="mt-2.5 text-sm text-fg-muted leading-relaxed">{p.body}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 02 — Data flow. -->
    <section class="bg-bg">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-10">
                <LocalEyebrow index="02" label="How it works" />
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    From exporter to dashboard, all on loopback
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                    One process owns the chDB connection and hosts OTLP ingest, the
                    <code class="text-primary font-mono text-[0.9em]">/local/query</code> API, and the dashboard
                    — all on one port. The CLI and the UI read your data over the very same HTTP contract.
                </p>
            </div>
            <LocalLoopback />
        </div>
    </section>

    <!-- 03 — UI showcase: traces. Prose left, artifact right. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-12">
                <LocalEyebrow index="03" label="The dashboard" />
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    The same dashboard, on your machine
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                    Hosted Maple's UI, served straight from your binary. Every view below runs against the
                    local <code class="text-primary font-mono text-[0.9em]">/local/query</code> API reading your
                    embedded store — no data leaves the machine.
                </p>
            </div>

            <div class="grid lg:grid-cols-[minmax(0,360px)_1fr] gap-12 lg:gap-16 items-start">
                <div class="lg:sticky lg:top-32">
                    <LocalEyebrow label="Traces" />
                    <h3 class="font-display text-2xl sm:text-3xl font-semibold leading-tight tracking-tight">
                        Full span trees with correlated logs
                    </h3>
                    <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed max-w-md">
                        Search spans by service, duration, or error, then drill into any trace for its complete
                        waterfall and the log lines emitted alongside it.
                    </p>
                </div>
                <div>
                    <LiveTrace />
                </div>
            </div>
        </div>
    </section>

    <!-- 04 — UI showcase: logs. Volume chart + raw stream, then prose. -->
    <section class="bg-bg">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid gap-4">
                <LiveLogsVolumeChart client:load />
                <LiveLogStream />
            </div>
            <div class="mt-12 max-w-2xl">
                <LocalEyebrow label="Logs" />
                <h3 class="font-display text-2xl sm:text-3xl font-semibold leading-tight tracking-tight">
                    Search the stream, cluster the noise
                </h3>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                    Filter by service, severity, text, or trace ID — or run
                    <code class="text-primary font-mono text-[0.9em]">log-patterns</code> to cluster lines into
                    templates and surface the noisiest sources at a glance.
                </p>
            </div>
        </div>
    </section>

    <!-- 05 — UI showcase: service map. Mirrored: artifact left, prose right. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid lg:grid-cols-[1fr_minmax(0,340px)] gap-12 lg:gap-16 items-start">
                <div>
                    <LiveServiceMap />
                </div>
                <div class="lg:sticky lg:top-32 lg:order-last">
                    <LocalEyebrow label="Service map" />
                    <h3 class="font-display text-2xl sm:text-3xl font-semibold leading-tight tracking-tight">
                        See how your services call each other
                    </h3>
                    <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed max-w-md">
                        Dependency edges with call counts, error rates, and latency — reconstructed from the
                        spans you've ingested, entirely on your machine.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- 06 — CLI surface. -->
    <section class="bg-bg">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-12">
                <LocalEyebrow index="04" label="The CLI" />
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    Drive it from your terminal
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                    The same binary is also a query CLI. Every command runs against the running server and
                    prints JSON by default — add <code class="text-primary font-mono text-[0.9em]">--format
                    table</code> for an aligned table, or <code class="text-primary font-mono text-[0.9em]"
                    >--debug</code> to see the compiled SQL.
                </p>
            </div>
            <LocalCommandGrid />
        </div>
    </section>

    <!-- 07 — Platforms / install recap. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,420px)] gap-12 lg:gap-16 items-start">
                <div>
                    <LocalEyebrow index="05" label="Install" />
                    <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                        Two files, one command
                    </h2>
                    <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed max-w-xl">
                        Homebrew downloads the matching bundle from the latest GitHub release, verifies its
                        checksum, and keeps the two files —
                        <code class="text-primary font-mono text-[0.9em]">maple</code> and
                        <code class="text-primary font-mono text-[0.9em]">libchdb</code> — together in its
                        Cellar, then links <code class="text-primary font-mono text-[0.9em]">maple</code> onto
                        your PATH. Prefer a standalone script? The curl installer still works.
                    </p>

                    <div class="mt-7 flex flex-wrap items-center gap-3">
                        <a
                            href="/docs/local-mode"
                            class="inline-flex h-9 items-center justify-center rounded-lg bg-primary px-3 text-xs font-medium text-primary-foreground transition-all hover:bg-primary/80"
                        >
                            Read the docs
                        </a>
                        <a
                            href="https://github.com/Makisuo/maple/releases"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex h-9 items-center justify-center rounded-lg border border-input bg-input/30 px-3 text-xs font-medium text-fg transition-all hover:bg-input/50"
                        >
                            GitHub Releases
                        </a>
                    </div>
                </div>

                <ul class="border border-border bg-bg-elevated divide-y divide-border">
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Platforms</span>
                        <span class="font-mono text-xs text-fg text-right"
                            >macOS (Apple Silicon)<br />Linux (x86_64 &amp; arm64)</span
                        >
                    </li>
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Bundle</span>
                        <span class="font-mono text-xs text-fg">maple + libchdb</span>
                    </li>
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Installs to</span>
                        <span class="font-mono text-xs text-fg">Homebrew Cellar</span>
                    </li>
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Upgrade</span>
                        <span class="font-mono text-xs text-fg">brew upgrade maple</span>
                    </li>
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Data</span>
                        <span class="font-mono text-xs text-fg">~/.maple/data</span>
                    </li>
                    <li class="flex items-baseline justify-between gap-4 px-5 py-3.5">
                        <span class="text-[10px] uppercase tracking-wider text-fg-muted">Uninstall</span>
                        <span class="font-mono text-xs text-fg">brew uninstall maple</span>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <BottomCTA />
    <Footer />
</Layout>

<style>
    /* Elevated value-prop cards (section 01): mono index, a top accent rule
       that wipes in on hover, and a subtle lift + amber tint. */
    .vp {
        position: relative;
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        padding: 22px 24px;
        overflow: hidden;
        transition:
            border-color 200ms ease,
            transform 200ms ease,
            background-color 200ms ease;
    }
    .vp::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(to right, var(--primary), transparent);
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .vp:hover {
        border-color: color-mix(in oklab, var(--primary) 40%, var(--border));
        transform: translateY(-3px);
        background: color-mix(in oklab, var(--primary) 4%, var(--bg-elevated));
    }
    .vp:hover::before {
        transform: scaleX(1);
    }
    .vp :global(h3) {
        padding-right: 30px;
    }
    .vp__idx {
        position: absolute;
        top: 18px;
        right: 18px;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        color: color-mix(in oklab, var(--muted-foreground) 65%, transparent);
        transition: color 200ms ease;
    }
    .vp:hover .vp__idx {
        color: var(--primary);
    }

    @media (prefers-reduced-motion: reduce) {
        .vp,
        .vp::before {
            transition: none;
        }
        .vp:hover {
            transform: none;
        }
        .vp::before {
            transform: scaleX(0);
        }
    }
</style>
