---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Sovereignty from "../components/Sovereignty.astro";
import LiveTrace from "../components/live/LiveTrace.astro";
import LiveLogStream from "../components/live/LiveLogStream.astro";
import LiveLogsVolumeChart from "../components/live/LiveLogsVolumeChart.tsx";
import LiveServiceMap from "../components/live/LiveServiceMap.astro";
import LiveMcpTranscript from "../components/live/LiveMcpTranscript.astro";
import LiveBrowserSessions from "../components/live/LiveBrowserSessions.astro";
import Kubernetes from "../components/Kubernetes.astro";
import BillComparison from "../components/BillComparison.astro";
import Quickstart from "../components/Quickstart.astro";
import Footer from "../components/Footer.astro";
import FAQ from "../components/FAQ.astro";
import SeoHead from "../components/SeoHead.astro";
import * as m from "../paraglide/messages";

const pageTitle = m.page_home_title();
const pageDescription = m.page_home_desc();

// Quotable, AI-extractable facts about Maple. Homepages are among the most-cited
// sources by AI chatbots, so we state the core entity facts plainly (and emit
// FAQPage schema via FAQ.astro).
const homeFaqs = [
    {
        question: "What is Maple?",
        answer:
            "Maple is an observability platform for traces, logs, and metrics, built on OpenTelemetry and backed by ClickHouse. It lets you collect, visualize, and query telemetry from distributed systems in real time — or let an AI agent do it for you over MCP.",
    },
    {
        question: "Is Maple open source?",
        answer:
            "Maple's source is on GitHub under the Functional Source License (FSL-1.1) — you can read every line, fork it, and self-host. Each release becomes Apache 2.0 two years after publication. You own your data and your instrumentation, and you can run Maple yourself or use the hosted version.",
    },
    {
        question: "Is Maple OpenTelemetry-native?",
        answer:
            "Yes. Maple is built on OpenTelemetry — the open, vendor-neutral standard for telemetry — so there are no proprietary agents and no lock-in. If you already emit OpenTelemetry data, you can point it at Maple without re-instrumenting your code.",
    },
    {
        question: "How is Maple priced?",
        answer:
            "The Startup plan is $39/month with 100 GB of logs, traces, and metrics each included, then a flat $0.30 per GB. No per-host or per-seat fees. Enterprise plans add custom volume and retention.",
    },
    {
        question: "Does Maple work with AI agents?",
        answer:
            "Yes. Maple ships a first-class MCP (Model Context Protocol) server, so compatible AI agents can list services, search traces, find errors, and propose fixes directly against your telemetry.",
    },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} type="SoftwareApplication" includeOrganization={true} />

    <Nav />
    <Hero />

    <span id="sovereignty"></span>
    <Sovereignty />

    <!-- 02 — Trace deep-dive. Prose left, artifact right. -->
    <section class="bg-bg">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid lg:grid-cols-[minmax(0,360px)_1fr] gap-12 lg:gap-16 items-start">
                <div class="lg:sticky lg:top-32">
                    <div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted mb-3">{m.trace_eyebrow()}</div>
                    <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                        {m.trace_title()}
                    </h2>
                    <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed max-w-md">{m.trace_lede()}</p>
                </div>
                <div>
                    <LiveTrace />
                </div>
            </div>
        </div>
    </section>

    <!-- 03 — Logs. Volume chart + raw stream, then prose. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid gap-4">
                <LiveLogsVolumeChart client:load />
                <LiveLogStream />
            </div>
            <div class="mt-12 max-w-2xl">
                <div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted mb-3">{m.logs_eyebrow()}</div>
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    {m.logs_title()}
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">{m.logs_lede()}</p>
            </div>
        </div>
    </section>

    <!-- 04 — Service map. Mirrored: prose right, artifact left. -->
    <section class="bg-bg">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="grid lg:grid-cols-[1fr_minmax(0,340px)] gap-12 lg:gap-16 items-start">
                <div>
                    <LiveServiceMap />
                </div>
                <div class="lg:sticky lg:top-32 lg:order-last">
                    <div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted mb-3">{m.map_eyebrow()}</div>
                    <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                        {m.map_title()}
                    </h2>
                    <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed max-w-md">{m.map_lede()}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 05 — MCP. Headline + lede first, full-width transcript below. -->
    <section class="bg-bg-deep">
        <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-12">
                <div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted mb-3">{m.mcp_eyebrow()}</div>
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    {m.mcp_title()}
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">{m.mcp_lede()}</p>
            </div>
            <LiveMcpTranscript />
        </div>
    </section>

    <!-- 06 — Browser sessions. Lede first, full-width replay artifact below. -->
    <section class="relative bg-bg overflow-hidden">
        <!-- Subtle dot-grid backdrop, faded toward the edges. -->
        <div
            class="absolute inset-0 pointer-events-none"
            aria-hidden="true"
            style="
                background-image: radial-gradient(oklch(1 0 0 / 5%) 1px, transparent 1px);
                background-size: 22px 22px;
                mask-image: radial-gradient(ellipse 80% 60% at 50% 20%, black, transparent 78%);
                -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 20%, black, transparent 78%);
            "
        ></div>

        <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-28">
            <div class="max-w-2xl mb-12">
                <div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted mb-3">{m.sessions_eyebrow()}</div>
                <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.04] tracking-tight">
                    {m.sessions_title()}
                </h2>
                <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">{m.sessions_lede()}</p>
            </div>
            <LiveBrowserSessions />
        </div>
    </section>

    <!-- 07 — Kubernetes. Prose left, workload table right. -->
    <Kubernetes />

    <BillComparison />

    <FAQ items={homeFaqs} />

    <Quickstart />

    <Footer />
</Layout>
