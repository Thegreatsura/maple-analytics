---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import FeatureHero from "../components/FeatureHero.astro";
import FeatureDetailGrid from "../components/FeatureDetailGrid.astro";
import RelatedFeatures from "../components/RelatedFeatures.astro";
import SeoHead from "../components/SeoHead.astro";
import BottomCTA from "../components/BottomCTA.astro";
import Footer from "../components/Footer.astro";
import * as m from "../paraglide/messages";

const pageTitle = m.page_otel_title();
const pageDescription = m.page_otel_desc();
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} type="WebPage" />
    <Nav />
    <FeatureHero
        label={m.page_otel_label()}
        title={m.page_otel_heading()}
        subtitle={m.page_otel_subtitle()}
    />

    <!-- What is OpenTelemetry -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">{m.page_otel_standard()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">{m.page_otel_what_is()}</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    {m.page_otel_what_is_p1()}
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    {m.page_otel_what_is_p2()}
                </p>
            </div>
        </div>
    </section>

    <!-- Why we build on OpenTelemetry -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">{m.page_otel_approach()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg mb-12 max-w-2xl">{m.page_otel_why_heading()}</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border">
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_no_vendor()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_no_vendor_desc()}</p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_one_standard()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_one_standard_desc()}</p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_community()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_community_desc()}</p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_language()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_language_desc()}</p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_future()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_future_desc()}</p>
                </div>
                <div class="bg-bg p-6 md:p-8">
                    <h3 class="text-base font-semibold text-fg mb-2">{m.page_otel_ecosystem_title()}</h3>
                    <p class="text-sm text-fg-muted leading-relaxed">{m.page_otel_ecosystem_desc()}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How Maple follows the spec -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">{m.page_otel_spec()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg mb-12 max-w-2xl">{m.page_otel_spec_heading()}</h2>
            <FeatureDetailGrid items={[
                { title: m.page_otel_spec_otlp(), description: m.page_otel_spec_otlp_desc() },
                { title: m.page_otel_spec_semantic(), description: m.page_otel_spec_semantic_desc() },
                { title: m.page_otel_spec_signals(), description: m.page_otel_spec_signals_desc() },
                { title: m.page_otel_spec_collector(), description: m.page_otel_spec_collector_desc() },
                { title: m.page_otel_spec_sdk(), description: m.page_otel_spec_sdk_desc() },
                { title: m.page_otel_spec_context(), description: m.page_otel_spec_context_desc() },
            ]} />
        </div>
    </section>

    <!-- OTel Ecosystem -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <span class="text-[11px] text-primary uppercase tracking-wider">{m.page_otel_ecosystem()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg max-w-2xl">{m.page_otel_ecosystem_heading()}</h2>
            <div class="mt-6 max-w-3xl space-y-4">
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    {m.page_otel_ecosystem_p1()}
                </p>
                <p class="text-sm md:text-base text-fg-muted leading-relaxed">
                    {m.page_otel_ecosystem_p2()}
                </p>
            </div>
        </div>
    </section>

    <RelatedFeatures current="" />
    <BottomCTA />
    <Footer />
</Layout>
