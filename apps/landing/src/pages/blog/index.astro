---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import SeoHead from "../../components/SeoHead.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { getSortedPosts, formatDate } from "../../lib/blog";

const posts = await getSortedPosts();
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = featured ? posts.filter((p) => p.id !== featured.id) : posts;

const total = posts.length;
const latest = posts[0]?.data.date;

const pageTitle = "Blog — Maple";
const pageDescription =
    "Engineering notes, guides, and product updates from the Maple team — OpenTelemetry, infrastructure observability, and transparent, open-source monitoring.";
---

<Layout title={pageTitle} description={pageDescription}>
    <SeoHead title={pageTitle} description={pageDescription} />
    <Nav />

    {/* ── Header ─────────────────────────────────────────────── */}
    <section class="relative overflow-hidden pt-[19px]">
        <div
            class="pointer-events-none absolute inset-0"
            aria-hidden="true"
            style="background-image: linear-gradient(to right, oklch(1 0 0 / 4%) 1px, transparent 1px), linear-gradient(to bottom, oklch(1 0 0 / 4%) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 60% at 30% 20%, black, transparent);"
        >
        </div>

        <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-10 md:pt-28 md:pb-14">
            <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.02em]">
                <span class="text-fg-muted">~/maple/blog</span>
                <span class="text-accent">$</span>
                <span class="text-fg-muted">ls posts/</span>
                <span class="inline-block h-[11px] w-[7px] bg-accent motion-safe:animate-pulse" aria-hidden="true"></span>
            </div>

            <div class="mt-5 flex flex-wrap items-end justify-between gap-6">
                <h1 class="m-0 font-display text-[clamp(34px,8vw,72px)] font-semibold leading-[0.95] tracking-[-0.035em] text-foreground">
                    Blog
                </h1>

                <ul
                    class="order-2 m-0 flex list-none border border-border p-0 sm:order-none"
                    style="background: color-mix(in oklab, var(--bg-elevated) 60%, transparent);"
                    aria-label="Blog stats"
                >
                    <li class="flex min-w-[92px] flex-col border-r border-border px-3 py-[7px]">
                        <span class="font-mono text-[9px] uppercase tracking-[0.12em] text-fg-muted">posts</span>
                        <span class="mt-0.5 font-mono text-[13px] tabular-nums text-foreground">{String(total).padStart(2, "0")}</span>
                    </li>
                    <li class="flex min-w-[92px] flex-col px-3 py-[7px]">
                        <span class="font-mono text-[9px] uppercase tracking-[0.12em] text-fg-muted">latest</span>
                        <span class="mt-0.5 font-mono text-[13px] tabular-nums text-foreground">{latest ? formatDate(latest) : "—"}</span>
                    </li>
                </ul>
            </div>

            <p class="mt-[22px] max-w-[62ch] text-sm leading-[1.7] text-fg-muted">
                Engineering notes, field guides, and product updates from the team building Maple —
                OpenTelemetry, infrastructure observability, and what transparent, open-source
                monitoring looks like in practice.
            </p>
        </div>
    </section>

    {/* ── Posts ──────────────────────────────────────────────── */}
    <section class="relative pb-20 md:pb-28">
        <div class="mx-auto max-w-6xl px-6">
            {posts.length === 0 ? (
                <div class="rounded-lg border border-border bg-card px-7 py-10 text-center">
                    <div class="inline-flex justify-center gap-2 font-mono text-xs">
                        <span class="text-fg-muted">~/maple/blog</span>
                        <span class="text-accent">$</span>
                        <span class="text-fg-muted">ls posts/</span>
                    </div>
                    <p class="mt-4 text-sm text-foreground">No posts published yet. The first writeups are on the way.</p>
                    <div class="mt-3.5 inline-flex items-center gap-2.5 font-mono text-xs text-fg-muted">
                        <a href="/docs" class="transition-colors hover:text-accent">read the docs</a>
                        <span aria-hidden="true">·</span>
                        <a href="/roadmap" class="transition-colors hover:text-accent">see the roadmap</a>
                    </div>
                </div>
            ) : (
                <>
                    {featured && (
                        <div class="mb-8 md:mb-12">
                            <PostCard post={featured} variant="featured" />
                        </div>
                    )}
                    {rest.length > 0 && (
                        <div class="grid gap-5 [grid-template-columns:repeat(auto-fit,minmax(300px,1fr))]">
                            {rest.map((post) => (
                                <PostCard post={post} />
                            ))}
                        </div>
                    )}
                </>
            )}
        </div>
    </section>

    <BottomCTA />
    <Footer />
</Layout>
