---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import FeatureHero from "../../components/FeatureHero.astro";
import StatsBanner from "../../components/StatsBanner.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import PainPoints from "../../components/PainPoints.astro";
import FeatureDetailGrid from "../../components/FeatureDetailGrid.astro";
import MigrationSteps from "../../components/MigrationSteps.astro";
import FAQ from "../../components/FAQ.astro";
import RelatedComparisons from "../../components/RelatedComparisons.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import Footer from "../../components/Footer.astro";
import SeoHead from "../../components/SeoHead.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { competitors, featureCategories } from "../../lib/competitors";

const competitor = competitors["new-relic"];
const pageTitle = `New Relic Alternative (Open Source) — Maple vs New Relic`;
const pageDescription = `Compare Maple and New Relic for observability. Maple offers unlimited team seats, no per-seat pricing, full open source transparency, and native OpenTelemetry support.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} competitorName="New Relic" />
    <Nav />
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Compare", href: "/compare/new-relic" }, { label: "New Relic" }]} />
    <FeatureHero
        label="Compare"
        title="Maple vs New Relic"
        subtitle="New Relic charges per seat and per GB, locking observability access behind per-user pricing. Its core platform is closed source, and switching away means rewriting your instrumentation. Maple gives you the same full-stack observability with transparent usage-based pricing, unlimited seats, and a fully open-source codebase you can self-host."
    />

    <StatsBanner stats={competitor.stats} />

    <ComparisonTable
        competitorName={competitor.name}
        features={competitor.features}
        featureCategories={featureCategories}
    />

    <PainPoints
        competitorName={competitor.name}
        painPoints={competitor.painPoints}
    />

    <!-- Why choose Maple -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10">
                <span class="inline-block border border-border px-3 py-1 text-[11px] text-accent uppercase tracking-wider mb-4">
                    Why choose Maple
                </span>
                <h2 class="text-2xl sm:text-3xl font-bold text-fg">Key advantages over New Relic</h2>
            </div>

            <FeatureDetailGrid items={[
                { title: "No per-seat pricing", description: "Add as many team members as you need. Maple charges based on data volume, not how many engineers need access to observability." },
                { title: "Fully open source", description: "Every line of code is open. Audit the platform, contribute improvements, and never worry about what happens behind closed doors." },
                { title: "OpenTelemetry native", description: "No proprietary agents required. Maple is built on OpenTelemetry standards, so your existing instrumentation works without modification." },
                { title: "AI & MCP integration", description: "AI-powered diagnostics and MCP tool integration help you find root causes faster with automated analysis workflows." },
                { title: "Self-hosting option", description: "Run Maple on your own infrastructure for full data sovereignty. Keep sensitive telemetry data within your network." },
                { title: "No vendor lock-in", description: "Built entirely on open standards. Your instrumentation, your data formats, and your export pipelines remain portable." },
            ]} />
        </div>
    </section>

    <MigrationSteps
        competitorName={competitor.name}
        steps={competitor.migrationSteps}
    />

    <FAQ items={competitor.faqs} />

    <RelatedComparisons
        currentSlug={competitor.slug}
        competitors={competitors}
    />

    <BottomCTA />
    <Footer />
</Layout>
