---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import FeatureHero from "../../components/FeatureHero.astro";
import StatsBanner from "../../components/StatsBanner.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import PainPoints from "../../components/PainPoints.astro";
import FeatureDetailGrid from "../../components/FeatureDetailGrid.astro";
import MigrationSteps from "../../components/MigrationSteps.astro";
import FAQ from "../../components/FAQ.astro";
import RelatedComparisons from "../../components/RelatedComparisons.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import Footer from "../../components/Footer.astro";
import SeoHead from "../../components/SeoHead.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { competitors, featureCategories } from "../../lib/competitors";
import * as m from "../../paraglide/messages";

const competitor = competitors.datadog;
const pageTitle = m.page_dd_title();
const pageDescription = m.page_dd_desc();
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} competitorName="Datadog" />
    <Nav />
    <Breadcrumb items={[{ label: m.breadcrumb_home(), href: "/" }, { label: m.breadcrumb_compare(), href: "/compare/datadog" }, { label: "Datadog" }]} />
    <FeatureHero
        label={m.page_compare_label()}
        title={m.page_dd_heading()}
        subtitle={m.page_dd_subtitle()}
    />

    <StatsBanner stats={competitor.stats} />

    <ComparisonTable
        competitorName={competitor.name}
        features={competitor.features}
        featureCategories={featureCategories}
    />

    <PainPoints
        competitorName={competitor.name}
        painPoints={competitor.painPoints}
    />

    <!-- Why choose Maple -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10">
                <span class="inline-block border border-border px-3 py-1 text-[11px] text-accent uppercase tracking-wider mb-4">
                    {m.page_compare_why()}
                </span>
                <h2 class="text-2xl sm:text-3xl font-bold text-fg">{m.page_dd_advantages()}</h2>
            </div>

            <FeatureDetailGrid items={[
                { title: m.page_dd_transparent(), description: m.page_dd_transparent_desc() },
                { title: m.page_dd_otel(), description: m.page_dd_otel_desc() },
                { title: m.page_dd_ai(), description: m.page_dd_ai_desc() },
                { title: m.page_dd_oss(), description: m.page_dd_oss_desc() },
                { title: m.page_dd_nolock(), description: m.page_dd_nolock_desc() },
                { title: m.page_dd_selfhost(), description: m.page_dd_selfhost_desc() },
            ]} />
        </div>
    </section>

    <MigrationSteps
        competitorName={competitor.name}
        steps={competitor.migrationSteps}
    />

    <FAQ items={competitor.faqs} />

    <RelatedComparisons
        currentSlug={competitor.slug}
        competitors={competitors}
    />

    <BottomCTA />
    <Footer />
</Layout>
