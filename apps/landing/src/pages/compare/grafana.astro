---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import FeatureHero from "../../components/FeatureHero.astro";
import StatsBanner from "../../components/StatsBanner.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import PainPoints from "../../components/PainPoints.astro";
import FeatureDetailGrid from "../../components/FeatureDetailGrid.astro";
import MigrationSteps from "../../components/MigrationSteps.astro";
import FAQ from "../../components/FAQ.astro";
import RelatedComparisons from "../../components/RelatedComparisons.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import Footer from "../../components/Footer.astro";
import SeoHead from "../../components/SeoHead.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { competitors, featureCategories } from "../../lib/competitors";

const competitor = competitors.grafana;
const pageTitle = `Grafana Alternative (Open Source) — Maple vs Grafana`;
const pageDescription = `Compare Maple and Grafana for observability. Maple replaces Loki, Tempo, Mimir, and Prometheus with a single unified platform — zero configuration, all signals correlated.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} competitorName="Grafana" />
    <Nav />
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Compare", href: "/compare/grafana" }, { label: "Grafana" }]} />
    <FeatureHero
        label="Compare"
        title="Maple vs Grafana"
        subtitle="Grafana is a powerful visualization layer, but building a full observability stack means configuring and maintaining Loki, Tempo, Mimir, and Prometheus separately — each with its own query language, scaling model, and failure modes. Maple gives you a unified platform where traces, logs, and metrics work together out of the box."
    />

    <StatsBanner stats={competitor.stats} />

    <ComparisonTable
        competitorName={competitor.name}
        features={competitor.features}
        featureCategories={featureCategories}
    />

    <PainPoints
        competitorName={competitor.name}
        painPoints={competitor.painPoints}
    />

    <!-- Why choose Maple -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10">
                <span class="inline-block border border-border px-3 py-1 text-[11px] text-accent uppercase tracking-wider mb-4">
                    Why choose Maple
                </span>
                <h2 class="text-2xl sm:text-3xl font-bold text-fg">Key advantages over Grafana</h2>
            </div>

            <FeatureDetailGrid items={[
                { title: "Unified platform", description: "No need to juggle Loki for logs, Tempo for traces, and Mimir for metrics. Maple combines all three signals in a single, cohesive platform." },
                { title: "Simpler self-hosting", description: "Deploy one service instead of managing multiple data stores, each with their own scaling and configuration requirements." },
                { title: "AI & MCP integration", description: "Built-in AI-powered diagnostics and MCP tool integration for automated root cause analysis — not available in the Grafana stack." },
                { title: "Native OpenTelemetry", description: "Purpose-built for OpenTelemetry from day one. No adapters, no translation layers, no compatibility surprises." },
                { title: "Built-in alerting", description: "Alerting is integrated into the platform, not bolted on as a separate component that needs its own configuration." },
                { title: "Zero configuration", description: "Start ingesting data in minutes. No PromQL to learn, no storage backends to tune, no data source connections to wire up." },
            ]} />
        </div>
    </section>

    <MigrationSteps
        competitorName={competitor.name}
        steps={competitor.migrationSteps}
    />

    <FAQ items={competitor.faqs} />

    <RelatedComparisons
        currentSlug={competitor.slug}
        competitors={competitors}
    />

    <BottomCTA />
    <Footer />
</Layout>
