---
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import FeatureHero from "../../../components/FeatureHero.astro";
import ComparisonTable from "../../../components/ComparisonTable.astro";
import FeatureDetailGrid from "../../../components/FeatureDetailGrid.astro";
import BottomCTA from "../../../components/BottomCTA.astro";
import Footer from "../../../components/Footer.astro";
import SeoHead from "../../../components/SeoHead.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { competitors, featureOrder } from "../../../lib/competitors";

const competitor = competitors.dash0;
const pageTitle = `Dash0 Alternative (Open Source) — Maple vs Dash0`;
const pageDescription = `Compare Maple and Dash0 for observability. Both are OpenTelemetry-native with transparent pricing and an MCP integration — Maple adds open source, self-hosting, and full control over your data.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} />
    <Nav />
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Compare" }, { label: "Dash0" }]} />
    <FeatureHero
        label="Compare"
        title="Maple vs Dash0"
        subtitle="Dash0 and Maple are both OpenTelemetry-native with transparent usage-based pricing and no per-seat fees. The difference is ownership: Maple is open source and self-hostable, so you can run it on your own infrastructure — including your own ClickHouse — for full data sovereignty and retention control, instead of a closed SaaS backend."
    />

    <ComparisonTable
        competitorName={competitor.name}
        features={competitor.features}
        featureOrder={featureOrder}
    />

    <!-- Why choose Maple -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10">
                <span class="inline-block border border-border px-3 py-1 text-[11px] text-primary uppercase tracking-wider mb-4">
                    Why choose Maple
                </span>
                <h2 class="text-2xl sm:text-3xl font-bold text-fg">Key advantages over Dash0</h2>
            </div>

            <FeatureDetailGrid items={[
                { title: "Open source", description: "Maple's source is available under the Functional Source License (FSL-1.1) — inspect every line, contribute features, and trust there are no black boxes. Dash0's backend is closed-source SaaS." },
                { title: "Self-hosting available", description: "Run Maple on your own infrastructure for data residency and compliance. Dash0 is SaaS-only, so your telemetry has to live in their cloud." },
                { title: "Full retention control", description: "Self-hosting puts you in control of retention and storage — keep data as long as your compliance and debugging workflows require, instead of fixed SaaS windows." },
                { title: "Your data, your perimeter", description: "Keep telemetry inside your own infrastructure for sovereignty and compliance — no third-party cloud sees your data unless you choose the hosted version." },
                { title: "Run on your own ClickHouse", description: "Maple's query engine speaks ClickHouse, so a self-hosted deployment can run on a ClickHouse instance you operate and scale yourself." },
                { title: "Drop-in pipeline migration", description: "Both platforms ingest standard OTLP, so moving your telemetry is just re-pointing your OpenTelemetry Collector exporter — no instrumentation changes. (Dashboards and alerts are recreated in Maple.)" },
            ]} />
        </div>
    </section>
    <BottomCTA />
    <Footer />
</Layout>
