{
	// Source wrangler config. `flue build --target cloudflare` reads this and
	// emits the deployable config to `dist/<name>/wrangler.json` (with Flue's
	// generated entrypoint + Durable Object bindings). Deploy the GENERATED one,
	// never this source file.
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "maple-chat-flue",
	"compatibility_date": "2026-06-01",
	"compatibility_flags": ["nodejs_compat"],
	// Workers AI binding — drives the `cloudflare/*` model provider (env.AI.run).
	"ai": {
		"binding": "AI",
	},
	// Flue-generated Durable Object classes. `FlueRegistry` is always present;
	// `FlueMapleChatAgent` is generated from `src/agents/maple-chat.ts` and
	// `FlueTriageWorkflow` from `src/workflows/triage.ts`.
	// Append-only once deployed: never rewrite a deployed migration tag.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["FlueRegistry", "FlueMapleChatAgent", "FlueTriageWorkflow"],
		},
	],
	"vars": {
		// Maple API worker that hosts the MCP server at `/mcp`.
		"MAPLE_API_URL": "http://localhost:3472",
	},
}
