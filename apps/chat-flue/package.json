{
	"name": "@maple/chat-flue",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "flue dev --target cloudflare",
		"build": "flue build --target cloudflare",
		"deploy": "flue build --target cloudflare && wrangler deploy --config dist/maple_chat_flue/wrangler.json",
		"connect": "flue connect maple-chat local",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@clerk/backend": "^2.30.1",
		"@flue/runtime": "1.0.0-beta.2",
		"agents": "^0.14.1",
		"hono": "^4.8.3",
		"valibot": "^1.1.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260603.1",
		"@flue/cli": "1.0.0-beta.1",
		"typescript": "catalog:tooling",
		"vitest": "catalog:",
		"wrangler": "^4.41.0"
	}
}
