{
  "name": "@maple/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:migrate": "mkdir -p .data && bun run --cwd ../../packages/db db:migrate",
    "dev": "bun run --env-file ../../.env.local --watch src/index.ts",
    "start": "bun run --env-file ../../.env.local src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "tinybird:dev": "tinybird dev",
    "tinybird:build": "tinybird build",
    "tinybird:deploy": "tinybird deploy"
  },
  "dependencies": {
    "@clerk/backend": "^2.30.1",
    "@effect/opentelemetry": "4.0.0-beta.33",
    "@effect/platform-bun": "4.0.0-beta.33",
    "@libsql/client": "0.15.15",
    "@maple/db": "workspace:*",
    "@maple/domain": "workspace:*",
    "@maple/query-engine": "workspace:*",
    "@tinybirdco/sdk": "0.0.60",
    "autumn-js": "^0.1.75",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "effect": "4.0.0-beta.33"
  },
  "devDependencies": {
    "@effect/language-service": "^0.75.1",
    "@types/bun": "^1.3.8",
    "@types/node": "^22.10.2",
    "atmn": "^1.0.1",
    "typescript": "^5.9.3"
  }
}
