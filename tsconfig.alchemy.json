{
	"compilerOptions": {
		"lib": ["esnext"],
		"target": "esnext",
		"module": "preserve",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"paths": {
			"@maple/infra/cloudflare": ["./packages/infra/src/cloudflare/index.ts"]
		}
	},
	"include": ["alchemy.run.ts", "apps/*/alchemy.run.ts"]
}
